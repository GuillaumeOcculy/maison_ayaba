# ============================================================
# Maison Ayaba — Variables d'environnement
# ============================================================
# Copiez ce fichier vers .env et remplissez les valeurs.
#
# Pour le deploiement Vercel :
#   Dashboard → Settings → Environment Variables
#   Ajoutez chaque variable ci-dessous pour Production.
# ============================================================

# URL du site (utilisee par astro.config.mjs et sitemap)
SITE=https://maison-ayaba.com

# Google Analytics 4 — Measurement ID
# Obtenez-le depuis : https://analytics.google.com → Admin → Data Streams
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
