---
import LandingLayout from '../../../layouts/LandingLayout.astro';
import LandingHero from '../../../components/landing/LandingHero.astro';
import LandingBody from '../../../components/landing/LandingBody.astro';
import { apartments } from '../../../data/apartments';
import { baseUrl } from '../../../data/siteConfig';
import salonHero from '../../../assets/images/hero/salon.png';
import terrasse from '../../../assets/images/apartments/terrasse2.png';
import salonWork from '../../../assets/images/apartments/salon3.png';

export function getStaticPaths() {
  return [
    {
      params: { variant: undefined },
      props: {
        variant: 'securite',
        image: salonHero,
        imageAlt: 'Bright living room of the Maison Ayaba apartment in Fidjrossè, Cotonou',
        frPath: '/fr/reserver-cotonou/',
      },
    },
    {
      params: { variant: 'no-surprises' },
      props: {
        variant: 'trust',
        image: salonHero,
        imageAlt: 'Bright living room of the Maison Ayaba apartment in Fidjrossè, Cotonou',
        frPath: '/fr/reserver-cotonou/sans-surprise/',
      },
    },
    {
      params: { variant: 'airport' },
      props: {
        variant: 'airport',
        image: terrasse,
        imageAlt: 'Terrace of the Maison Ayaba apartment in Fidjrossè, Cotonou',
        frPath: '/fr/reserver-cotonou/aeroport/',
      },
    },
    {
      params: { variant: 'wifi' },
      props: {
        variant: 'wifi',
        image: salonWork,
        imageAlt: 'Living space of the Maison Ayaba apartment in Fidjrossè, Cotonou',
        frPath: '/fr/reserver-cotonou/wifi/',
      },
    },
  ];
}

const { variant, image, imageAlt, frPath } = Astro.props as {
  variant: 'securite' | 'trust' | 'airport' | 'wifi';
  image: ImageMetadata;
  imageAlt: string;
  frPath: string;
};

// Generic CTAs (header, hero, final CTA) → listing matched to the variant's audience.
// securite (solo / safety campaign) → 1-bedroom ; other variants → 3-bedroom (largest basket).
const ctaApartmentByVariant: Record<'securite' | 'trust' | 'airport' | 'wifi', number> = {
  securite: 0,
  trust: 2,
  airport: 2,
  wifi: 2,
};
const ctaHref = apartments[ctaApartmentByVariant[variant]].airbnbUrl;
// Offer section: one link per format (1 / 2 / 3 bedrooms), in order.
const formatHrefs = apartments.map((a) => a.airbnbUrl);

const title = 'Apartment in Cotonou, Fidjrossè — safe neighborhood, no nasty surprises | Maison Ayaba';
const description =
  'Apartment in Fidjrossè, a safe residential area (night guard, next to the Lycée International Français). Verified 5/5 reviews, true-to-life photos, air conditioning, complimentary airport transfer. From €40/night, payment protected by Airbnb.';
const canonical = `${baseUrl}${Astro.url.pathname}`;
const alternates = [
  { hreflang: 'en', href: canonical },
  { hreflang: 'fr', href: `${baseUrl}${frPath}` },
  { hreflang: 'x-default', href: `${baseUrl}${frPath}` },
];
---
<LandingLayout
  locale="en"
  title={title}
  description={description}
  canonical={canonical}
  ctaText="Book on Airbnb"
  ctaHref={ctaHref}
  alternates={alternates}
>
  <LandingHero locale="en" variant={variant} image={image} imageAlt={imageAlt} ctaHref={ctaHref} />
  <LandingBody locale="en" ctaHref={ctaHref} formatHrefs={formatHrefs} />
</LandingLayout>
