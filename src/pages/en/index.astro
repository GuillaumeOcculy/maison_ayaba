---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../../components/sections/HeroSection.astro';
import ApartmentGrid from '../../components/sections/ApartmentGrid.astro';

import FaqSection from '../../components/sections/FaqSection.astro';
import FinalCta from '../../components/sections/FinalCta.astro';
import SchemaOrg from '../../components/seo/SchemaOrg.astro';
import { t } from '../../i18n/utils';
import heroImage from '../../assets/images/hero/salon.png';

const locale = 'en' as const;
---
<BaseLayout
  locale={locale}
  title="Maison Ayaba — Furnished Apartment in Fidjrossè, Cotonou"
  description={t(locale, 'home.heroSubtitle')}
  hideHeader={true}
>
  <Fragment slot="head">
    <SchemaOrg type="LodgingBusiness" locale={locale} />
    <SchemaOrg type="WebSite" locale={locale} />
    <SchemaOrg type="SiteNavigationElement" locale={locale} />
  </Fragment>
  <HeroSection
    image={heroImage}
    imageAlt="Bright living room at Maison Ayaba in Fidjrosse, Cotonou"
    label={t(locale, 'home.heroLabel')}
    title={t(locale, 'home.heroTitle')}
    subtitle={t(locale, 'home.heroSubtitle')}
    stats={[
      { value: t(locale, 'home.statPriceValue'), label: t(locale, 'home.statPriceLabel'), oldPrice: t(locale, 'home.statPriceOld'), promoBadge: t(locale, 'home.statPricePromo') },
      { value: t(locale, 'home.statConfigsValue'), label: t(locale, 'home.statConfigsLabel') },
      { value: t(locale, 'home.statGuestsValue'), label: t(locale, 'home.statGuestsLabel') },
      { value: t(locale, 'home.statBeachValue'), label: t(locale, 'home.statBeachLabel') },
    ]}
    primaryCta={{ text: t(locale, 'home.heroPrimaryCta'), href: '/en/apartment/#book' }}
    secondaryCta={{ text: t(locale, 'home.heroSecondaryCta'), href: '#configurations' }}
  />

  <ApartmentGrid locale={locale} />

  <FaqSection locale={locale} />

  <FinalCta
    title={t(locale, 'home.finalCtaTitle')}
    subtitle={t(locale, 'home.finalCtaSubtitle')}
    ctaText={t(locale, 'home.finalCtaCta')}
    ctaHref="/en/apartment/#book"
  />
</BaseLayout>
