---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import AirbnbCta from '../../components/ui/AirbnbCta.astro';
import FinalCta from '../../components/sections/FinalCta.astro';
import SchemaOrg from '../../components/seo/SchemaOrg.astro';
import { apartments } from '../../data/apartments';
import { t } from '../../i18n/utils';
import { whatsappNumber } from '../../data/siteConfig';
import chambre1Img from '../../assets/images/apartments/chambre1.png';
import chambre1Img2 from '../../assets/images/apartments/chambre1-2.png';
import chambre1Img3 from '../../assets/images/apartments/chambre1-3.png';
import chambre1Sdb from '../../assets/images/apartments/chambre1-sdb.png';
import chambre2Img from '../../assets/images/apartments/chambre2.png';
import chambre2Img2 from '../../assets/images/apartments/chambre2-2.png';
import chambre2Img3 from '../../assets/images/apartments/chambre2-3.png';
import chambre2Img4 from '../../assets/images/apartments/chambre2-4.png';
import chambre3Img from '../../assets/images/apartments/chambre3.png';
import chambre3Img2 from '../../assets/images/apartments/chambre3-2.png';
import chambre3Img3 from '../../assets/images/apartments/chambre3-3.png';
import chambre3Img4 from '../../assets/images/apartments/chambre3-4.png';
import chambre3Img5 from '../../assets/images/apartments/chambre3-5.png';
import chambre3Sdb from '../../assets/images/apartments/chambre3-sdb.png';
import chambre3Sdb2 from '../../assets/images/apartments/chambre3-sdb2.png';

const locale = 'en' as const;

const configImages: ImageMetadata[][] = [
  [chambre1Img, chambre1Img2, chambre1Img3, chambre1Sdb],
  [chambre2Img, chambre2Img2, chambre2Img3, chambre2Img4],
  [chambre3Img, chambre3Img2, chambre3Img3, chambre3Sdb, chambre3Sdb2, chambre3Img4, chambre3Img5],
];
const configIds: ('1ch' | '2ch' | '3ch')[] = ['1ch', '2ch', '3ch'];
const configNameKeys = ['home.config1chName', 'home.config2chName', 'home.config3chName'];
const configNoteKeys = ['home.config1chNote', 'home.config2chNote', 'home.config3chNote'];
const configSubtitleKeys = ['home.config1chSubtitle', 'home.config2chSubtitle', 'home.config3chSubtitle'];

const whatsappUrl = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(t(locale, 'social.whatsappMessage'))}`;
---
<BaseLayout
  locale={locale}
  title={t(locale, 'booking.pageTitle')}
  description={t(locale, 'booking.pageDescription')}
>
  <Fragment slot="head">
    <SchemaOrg type="LodgingBusiness" locale={locale} includeOffers />
    <SchemaOrg type="BreadcrumbList" locale={locale} breadcrumbItems={[{ name: t(locale, 'nav.home'), url: '/en/' }, { name: t(locale, 'nav.book'), url: '/en/book/' }]} />
  </Fragment>
  {/* Compact hero */}
  <section class="bg-white pt-16 pb-10 lg:pt-20 lg:pb-12">
    <div class="max-w-[1200px] mx-auto px-6 lg:px-16 text-center">
      <h1 class="font-heading text-ayaba-dark text-[32px] lg:text-[40px] font-bold mb-3">
        {t(locale, 'booking.heroTitle')}
      </h1>
      <p class="text-ayaba-muted text-base lg:text-lg max-w-2xl mx-auto">
        {t(locale, 'booking.heroSubtitle')}
      </p>
    </div>
  </section>

  {/* 3 recap cards */}
  <section class="bg-white pb-16 lg:pb-20">
    <div class="max-w-[1200px] mx-auto px-6 lg:px-16">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[0, 1, 2].map((i) => {
          const apt = apartments[i];
          return (
          <div class="bg-white border border-gray-100 rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow">
            <div class="relative aspect-[4/3] overflow-hidden group">
              <div id={`book-slider-${configIds[i]}`} class="flex h-full transition-transform duration-300 ease-out" style="will-change: transform">
                {configImages[i].map((img, idx) => (
                  <div class="w-full h-full shrink-0">
                    <Image
                      src={img}
                      alt={`${t(locale, configNameKeys[i])} — ${idx + 1}`}
                      class="w-full h-full object-cover"
                      widths={[400, 640]}
                      sizes="(max-width: 768px) 100vw, 33vw"
                      loading="lazy"
                    />
                  </div>
                ))}
              </div>
              {configImages[i].length > 1 && (
                <>
                  <button type="button" data-slider={`book-slider-${configIds[i]}`} data-dir="prev" aria-label="Previous image" class="absolute left-2 top-1/2 -translate-y-1/2 bg-white/80 hover:bg-white rounded-full w-8 h-8 flex items-center justify-center shadow opacity-0 group-hover:opacity-100 transition-opacity">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M15 19l-7-7 7-7"/></svg>
                  </button>
                  <button type="button" data-slider={`book-slider-${configIds[i]}`} data-dir="next" aria-label="Next image" class="absolute right-2 top-1/2 -translate-y-1/2 bg-white/80 hover:bg-white rounded-full w-8 h-8 flex items-center justify-center shadow opacity-0 group-hover:opacity-100 transition-opacity">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7"/></svg>
                  </button>
                  <div class="absolute bottom-2 left-1/2 -translate-x-1/2 flex gap-1.5">
                    {configImages[i].map((_, idx) => (
                      <span data-dot={`book-slider-${configIds[i]}`} data-index={idx} class:list={["w-2 h-2 rounded-full transition-colors", idx === 0 ? "bg-white" : "bg-white/50"]} />
                    ))}
                  </div>
                </>
              )}
            </div>
            <div class="p-6">
              <p class="text-ayaba-gold text-xs uppercase tracking-[1.5px] font-semibold mb-1">
                {t(locale, configNoteKeys[i])}
              </p>
              <h2 class="font-heading text-ayaba-dark text-xl font-bold mb-2">
                {t(locale, configNameKeys[i])}
              </h2>
              <div class="flex items-baseline gap-2 mb-1">
                <span class="text-ayaba-terra font-bold text-2xl">€{apt.pricePerNight.min} – €{apt.pricePerNight.max}</span>
                <span class="text-ayaba-muted text-sm">{t(locale, 'labels.pricePerNight')}</span>
              </div>
              <p class="text-ayaba-muted text-sm mb-4">
                {t(locale, configSubtitleKeys[i])}
              </p>
              <p class="text-[11px] uppercase tracking-[1.5px] text-ayaba-terra font-semibold mb-2">{t(locale, 'home.bonusLabel')}</p>
              <ul class="space-y-1.5 mb-5">
                <li class="flex items-center gap-2"><span class="text-ayaba-terra font-bold text-sm" aria-hidden="true">&#9733;</span><span class="text-ayaba-dark text-sm">{t(locale, 'home.bonusWelcomeBasket')}</span></li>
                <li class="flex items-center gap-2"><span class="text-ayaba-terra font-bold text-sm" aria-hidden="true">&#9733;</span><span class="text-ayaba-dark text-sm">{t(locale, 'home.bonusCleaning')}</span></li>
                <li class="flex items-center gap-2"><span class="text-ayaba-terra font-bold text-sm" aria-hidden="true">&#9733;</span><span class="text-ayaba-dark text-sm">{t(locale, 'home.bonusConcierge')}</span></li>
                <li class="flex items-center gap-2"><span class="text-ayaba-terra font-bold text-sm" aria-hidden="true">&#9733;</span><span class="text-ayaba-dark text-sm">{t(locale, 'home.bonusTransfer')}</span></li>
              </ul>
              <AirbnbCta configId={configIds[i]} variant="primary" size="large" locale={locale} />
            </div>
          </div>
          );
        })}
      </div>
    </div>
  </section>

  {/* Final CTA — WhatsApp for questions */}
  <FinalCta
    title={t(locale, 'booking.finalCtaTitle')}
    subtitle={t(locale, 'booking.finalCtaSubtitle')}
    ctaText={t(locale, 'booking.finalCtaCta')}
    ctaHref={whatsappUrl}
    isExternal
  />
</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    function updateSlider(track: HTMLElement, newIndex: number) {
      const count = track.children.length;
      const current = ((newIndex % count) + count) % count;
      track.dataset.current = String(current);
      track.style.transform = `translateX(-${current * 100}%)`;
      document.querySelectorAll<HTMLSpanElement>(`[data-dot="${track.id}"]`).forEach((dot) => {
        const idx = parseInt(dot.dataset.index || '0', 10);
        dot.className = `w-2 h-2 rounded-full transition-colors ${idx === current ? 'bg-white' : 'bg-white/50'}`;
      });
    }

    document.querySelectorAll<HTMLButtonElement>('[data-slider][data-dir]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const track = document.getElementById(btn.dataset.slider!);
        if (!track) return;
        const current = parseInt(track.dataset.current || '0', 10);
        updateSlider(track, btn.dataset.dir === 'next' ? current + 1 : current - 1);
      });
    });

    document.querySelectorAll<HTMLElement>('[id^="book-slider-"]').forEach((track) => {
      const container = track.parentElement;
      if (!container) return;
      let startX = 0, startY = 0, isDragging = false;

      container.addEventListener('touchstart', (e) => {
        startX = e.touches[0].clientX; startY = e.touches[0].clientY; isDragging = true;
      }, { passive: true });

      container.addEventListener('touchmove', (e) => {
        if (!isDragging) return;
        const dx = e.touches[0].clientX - startX, dy = e.touches[0].clientY - startY;
        if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 10) e.preventDefault();
      }, { passive: false });

      container.addEventListener('touchend', (e) => {
        if (!isDragging) return;
        isDragging = false;
        const dx = e.changedTouches[0].clientX - startX;
        if (Math.abs(dx) > 50) {
          const current = parseInt(track.dataset.current || '0', 10);
          updateSlider(track, dx < 0 ? current + 1 : current - 1);
        }
      }, { passive: true });
    });
  });
</script>
