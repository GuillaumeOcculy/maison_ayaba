---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import NeighborhoodSection from '../../components/sections/NeighborhoodSection.astro';
import TransportSection from '../../components/sections/TransportSection.astro';
import FinalCta from '../../components/sections/FinalCta.astro';
import SchemaOrg from '../../components/seo/SchemaOrg.astro';
import { neighborhoodSections, transportModes } from '../../data/neighborhood';
import { t } from '../../i18n/utils';
import salon1 from '../../assets/images/apartments/salon1.png';
import salon2 from '../../assets/images/apartments/salon2.png';
import salon3 from '../../assets/images/apartments/salon3.png';

const locale = 'fr' as const;

const bgClasses: Record<string, string> = {
  restaurants: 'bg-ayaba-cream',
  commerces: 'bg-white',
  plage: 'bg-white',
  pointsInteret: 'bg-ayaba-cream',
};

const sectionsBeforeTransport = neighborhoodSections.filter(s => ['restaurants', 'commerces'].includes(s.id));
const sectionsAfterTransport = neighborhoodSections.filter(s => ['plage', 'pointsInteret'].includes(s.id));

const resolvedTransportModes = transportModes.map((mode) => ({
  name: t(locale, mode.nameKey),
  description: t(locale, mode.descriptionKey),
  price: t(locale, mode.priceKey),
  tip: mode.tipKey ? t(locale, mode.tipKey) : undefined,
}));
---
<BaseLayout
  locale={locale}
  title={t(locale, 'neighborhood.pageTitle')}
  description={t(locale, 'neighborhood.pageDescription')}
>
  <Fragment slot="head">
    <SchemaOrg type="FAQPage" locale={locale} faqItems={[
      { question: t(locale, 'neighborhood.faqRestaurantsQ'), answer: t(locale, 'neighborhood.faqRestaurantsA') },
      { question: t(locale, 'neighborhood.faqTransportQ'), answer: t(locale, 'neighborhood.faqTransportA') },
      { question: t(locale, 'neighborhood.faqPlageQ'), answer: t(locale, 'neighborhood.faqPlageA') },
    ]} />
    <SchemaOrg type="BreadcrumbList" locale={locale} breadcrumbItems={[{ name: t(locale, 'nav.home'), url: '/' }, { name: t(locale, 'nav.neighborhood'), url: '/fr/fidjrosse-cotonou/' }]} />
  </Fragment>
  {/* Hero compact */}
  <section class="bg-white pt-16 pb-10 lg:pt-20 lg:pb-12">
    <div class="max-w-[1200px] mx-auto px-6 lg:px-16 text-center">
      <h1 class="font-heading text-ayaba-dark text-[32px] lg:text-[40px] font-bold mb-3">
        {t(locale, 'neighborhood.heroTitle')}
      </h1>
      <p class="text-ayaba-muted text-base lg:text-lg max-w-2xl mx-auto">
        {t(locale, 'neighborhood.heroSubtitle')}
      </p>
    </div>
  </section>

  {/* Intro quartier */}
  <section class="bg-white pb-12 lg:pb-16">
    <div class="max-w-[800px] mx-auto px-6 lg:px-16">
      <h2 class="font-heading text-ayaba-dark text-[24px] lg:text-[28px] font-bold mb-4">
        {t(locale, 'neighborhood.introTitle')}
      </h2>
      <p class="text-ayaba-muted text-base leading-relaxed">
        {t(locale, 'neighborhood.introDesc')}
      </p>
    </div>
  </section>

  {/* Sections Restaurants & Commerces */}
  {sectionsBeforeTransport.map((section) => (
    <NeighborhoodSection
      title={t(locale, section.titleKey)}
      description={section.descriptionKey ? t(locale, section.descriptionKey) : undefined}
      items={section.items.map((item) => ({
        name: t(locale, item.nameKey),
        detail: t(locale, item.detailKey),
        url: item.url,
      }))}
      icon={section.icon}
      bgClass={bgClasses[section.id]}
      columns={section.columns}
    />
  ))}

  {/* CTA léger après Restaurants & Commerces */}
  <div class="bg-white py-8">
    <div class="max-w-[800px] mx-auto px-6 lg:px-16 text-center">
      <p class="text-ayaba-muted text-sm mb-2">{t(locale, 'neighborhood.inlineCta1')}</p>
      <a
        href="/fr/appartement/"
        class="text-ayaba-terra hover:text-ayaba-terra/80 font-semibold text-sm underline underline-offset-4 transition-colors"
      >
        {t(locale, 'neighborhood.inlineCtaLink')} →
      </a>
    </div>
  </div>

  {/* Section Transports */}
  <TransportSection
    title={t(locale, 'neighborhood.sectionTransportsTitle')}
    description={t(locale, 'neighborhood.sectionTransportsDesc')}
    modes={resolvedTransportModes}
    bgClass="bg-ayaba-cream"
  />

  {/* Sections Plage & Points d'intérêt */}
  {sectionsAfterTransport.map((section) => (
    <NeighborhoodSection
      title={t(locale, section.titleKey)}
      description={section.descriptionKey ? t(locale, section.descriptionKey) : undefined}
      items={section.items.map((item) => ({
        name: t(locale, item.nameKey),
        detail: t(locale, item.detailKey),
        url: item.url,
      }))}
      icon={section.icon}
      bgClass={bgClasses[section.id]}
      columns={section.columns}
    />
  ))}

  {/* CTA léger après Plage & Points d'intérêt */}
  <div class="bg-white py-8">
    <div class="max-w-[800px] mx-auto px-6 lg:px-16 text-center">
      <p class="text-ayaba-muted text-sm mb-2">{t(locale, 'neighborhood.inlineCta2')}</p>
      <a
        href="/fr/appartement/"
        class="text-ayaba-terra hover:text-ayaba-terra/80 font-semibold text-sm underline underline-offset-4 transition-colors"
      >
        {t(locale, 'neighborhood.inlineCtaLink')} →
      </a>
    </div>
  </div>

  {/* Mini-encart offre */}
  <section class="bg-ayaba-cream py-16 lg:py-20">
    <div class="max-w-[800px] mx-auto px-6 lg:px-16 text-center">
      <h2 class="font-heading text-ayaba-dark text-[26px] lg:text-[32px] font-bold mb-3">
        {t(locale, 'neighborhood.offerTitle')}
      </h2>
      <p class="text-ayaba-muted text-base max-w-2xl mx-auto mb-8">
        {t(locale, 'neighborhood.offerSubtitle')}
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
        <div class="bg-white rounded-xl overflow-hidden shadow-sm">
          <Image src={salon1} alt="Salon du logement Duo" width={400} height={260} class="w-full h-36 object-cover" loading="lazy" />
          <p class="text-ayaba-dark font-semibold text-sm p-4">{t(locale, 'neighborhood.offerDuo')}</p>
        </div>
        <div class="bg-white rounded-xl overflow-hidden shadow-sm">
          <Image src={salon2} alt="Salon du logement Famille" width={400} height={260} class="w-full h-36 object-cover" loading="lazy" />
          <p class="text-ayaba-dark font-semibold text-sm p-4">{t(locale, 'neighborhood.offerFamille')}</p>
        </div>
        <div class="bg-white rounded-xl overflow-hidden shadow-sm">
          <Image src={salon3} alt="Salon du logement Tribu" width={400} height={260} class="w-full h-36 object-cover" loading="lazy" />
          <p class="text-ayaba-dark font-semibold text-sm p-4">{t(locale, 'neighborhood.offerTribu')}</p>
        </div>
      </div>
      <p class="text-ayaba-terra font-bold text-lg mb-6">{t(locale, 'neighborhood.offerFrom')}</p>
      <a
        href="/fr/appartement/"
        class="inline-flex items-center justify-center bg-ayaba-terra text-white font-semibold text-base px-8 py-3 rounded-full hover:bg-ayaba-terra/90 transition-colors min-h-[44px] focus:outline-2 focus:outline-offset-2 focus:outline-ayaba-terra"
      >
        {t(locale, 'neighborhood.offerCta')}
      </a>
    </div>
  </section>

  {/* Final CTA */}
  <FinalCta
    title={t(locale, 'neighborhood.finalCtaTitle')}
    subtitle={t(locale, 'neighborhood.finalCtaSubtitle')}
    ctaText={t(locale, 'neighborhood.finalCtaCta')}
    ctaHref="/fr/appartement/#reserver"
  />
</BaseLayout>
