---
import LandingLayout from '../../../layouts/LandingLayout.astro';
import LandingHero from '../../../components/landing/LandingHero.astro';
import LandingBody from '../../../components/landing/LandingBody.astro';
import { apartments } from '../../../data/apartments';
import { baseUrl } from '../../../data/siteConfig';
import salonHero from '../../../assets/images/hero/salon.png';
import terrasse from '../../../assets/images/apartments/terrasse2.png';
import salonWork from '../../../assets/images/apartments/salon3.png';

export function getStaticPaths() {
  return [
    {
      params: { variant: undefined },
      props: {
        variant: 'securite',
        image: salonHero,
        imageAlt: "Salon lumineux de l'appartement Maison Ayaba à Fidjrossè, Cotonou",
        enPath: '/en/book-cotonou/',
      },
    },
    {
      params: { variant: 'sans-surprise' },
      props: {
        variant: 'trust',
        image: salonHero,
        imageAlt: "Salon lumineux de l'appartement Maison Ayaba à Fidjrossè, Cotonou",
        enPath: '/en/book-cotonou/no-surprises/',
      },
    },
    {
      params: { variant: 'aeroport' },
      props: {
        variant: 'airport',
        image: terrasse,
        imageAlt: "Terrasse de l'appartement Maison Ayaba à Fidjrossè, Cotonou",
        enPath: '/en/book-cotonou/airport/',
      },
    },
    {
      params: { variant: 'wifi' },
      props: {
        variant: 'wifi',
        image: salonWork,
        imageAlt: "Espace de vie de l'appartement Maison Ayaba à Fidjrossè, Cotonou",
        enPath: '/en/book-cotonou/wifi/',
      },
    },
  ];
}

const { variant, image, imageAlt, enPath } = Astro.props as {
  variant: 'securite' | 'trust' | 'airport' | 'wifi';
  image: ImageMetadata;
  imageAlt: string;
  enPath: string;
};

// CTA génériques (header, hero, CTA final) → annonce 3 chambres (plus gros panier).
const ctaHref = apartments[2].airbnbUrl;
// Section offre : un lien par format (1 / 2 / 3 chambres), dans l'ordre.
const formatHrefs = apartments.map((a) => a.airbnbUrl);

const title = 'Appartement à Cotonou, Fidjrossè — quartier sûr, sans mauvaise surprise | Maison Ayaba';
const description =
  "Appartement à Fidjrossè, quartier résidentiel sécurisé (gardien la nuit, à côté du Lycée International Français). Avis 5/5 vérifiés, photos fidèles, climatisation, transfert aéroport offert. Dès 40 €/nuit, paiement protégé Airbnb.";
const canonical = `${baseUrl}${Astro.url.pathname}`;
const alternates = [
  { hreflang: 'fr', href: canonical },
  { hreflang: 'en', href: `${baseUrl}${enPath}` },
  { hreflang: 'x-default', href: canonical },
];
---
<LandingLayout
  locale="fr"
  title={title}
  description={description}
  canonical={canonical}
  ctaText="Réserver sur Airbnb"
  ctaHref={ctaHref}
  alternates={alternates}
>
  <LandingHero locale="fr" variant={variant} image={image} imageAlt={imageAlt} ctaHref={ctaHref} />
  <LandingBody locale="fr" ctaHref={ctaHref} formatHrefs={formatHrefs} />
</LandingLayout>
