---
import { Image } from 'astro:assets';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SchemaOrg from '../../../components/seo/SchemaOrg.astro';
import FinalCta from '../../../components/sections/FinalCta.astro';
import { getCollection } from 'astro:content';
import { t } from '../../../i18n/utils';
import safetyImg from '../../../assets/images/blog/cotonou.jpg';
import transportImg from '../../../assets/images/blog/taxi.jpg';
import apartmentImg from '../../../assets/images/blog/apartment-interior.jpg';
import electriciteImg from '../../../assets/images/blog/electricite.jpg';
import fidjrosseImg from '../../../assets/images/blog/fidjrosse.jpg';
import apartmentHotelImg from '../../../assets/images/blog/apartment-hotel.jpg';
import cotonouCityImg from '../../../assets/images/blog/cotonou-city.jpg';
import beninTravelImg from '../../../assets/images/blog/benin-travel.jpg';
import digitalNomadImg from '../../../assets/images/blog/digital-nomad.jpg';
import cuisineImg from '../../../assets/images/blog/cuisine-beninoise.jpg';

const locale = 'fr';
const allPosts = await getCollection('blog');
const frPosts = allPosts
  .filter((post) => post.id.startsWith('fr/'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const pageTitle = t(locale, 'blog.pageTitle');
const pageDescription = t(locale, 'blog.pageDescription');

const breadcrumbItems = [
  { name: t(locale, 'nav.home'), url: '/' },
  { name: t(locale, 'nav.blog'), url: '/fr/blog/' },
];

const heroImages: Record<string, { src: ImageMetadata; alt: string }> = {
  'securite-cotonou': { src: safetyImg, alt: 'Rue animée à Cotonou' },
  'transport-cotonou': { src: transportImg, alt: 'Transport à Cotonou' },
  'appartement-meuble-cotonou': { src: apartmentImg, alt: 'Appartement meublé' },
  'coupures-electricite-cotonou': { src: electriciteImg, alt: 'Coupures d\'électricité à Cotonou' },
  'quartier-fidjrosse-cotonou': { src: fidjrosseImg, alt: 'Quartier Fidjrossè, Cotonou' },
  'appartement-vs-hotel-cotonou': { src: apartmentHotelImg, alt: 'Appartement vs hôtel' },
  'que-faire-cotonou': { src: cotonouCityImg, alt: 'Que faire à Cotonou' },
  'voyager-benin-guide': { src: beninTravelImg, alt: 'Voyager au Bénin' },
  'digital-nomad-cotonou': { src: digitalNomadImg, alt: 'Digital nomad à Cotonou' },
  'cuisine-beninoise-guide': { src: cuisineImg, alt: 'Cuisine béninoise' },
};

const tagColors = [
  'bg-ayaba-terra/10 text-ayaba-terra',
  'bg-ayaba-gold/15 text-ayaba-dark',
  'bg-ayaba-success/10 text-ayaba-success',
];
---
<BaseLayout locale={locale} title={pageTitle} description={pageDescription}>
  <SchemaOrg type="BreadcrumbList" locale={locale} breadcrumbItems={breadcrumbItems} />

  {/* Hero */}
  <section class="bg-white pt-16 pb-10 lg:pt-20 lg:pb-12">
    <div class="max-w-[1200px] mx-auto px-6 lg:px-16 text-center">
      <p class="text-ayaba-terra font-body text-sm font-semibold tracking-wider uppercase mb-4">Blog</p>
      <h1 class="font-heading text-ayaba-dark text-[32px] lg:text-[40px] font-bold mb-3">
        {t(locale, 'blog.heroTitle')}
      </h1>
      <p class="text-ayaba-muted text-base lg:text-lg max-w-2xl mx-auto">
        {t(locale, 'blog.heroSubtitle')}
      </p>
    </div>
  </section>

  {/* Articles */}
  <section class="bg-ayaba-cream py-16 lg:py-20">
    <div class="max-w-[1200px] mx-auto px-6 lg:px-16">
      <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-3">
        {frPosts.map((post, index) => {
          const slug = post.id.replace(/^fr\//, '');
          const hero = heroImages[slug];
          const formattedDate = post.data.pubDate.toLocaleDateString('fr-FR', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          });
          return (
            <>
              <article class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-lg hover:-translate-y-1 transition-all duration-300 flex flex-col">
                <a href={`/fr/blog/${slug}/`} class="block">
                  {hero ? (
                    <Image
                      src={hero.src}
                      alt={hero.alt}
                      widths={[400, 600]}
                      sizes="(max-width: 768px) 100vw, 400px"
                      class="w-full h-52 object-cover"
                      loading="lazy"
                    />
                  ) : (
                    <div class="h-52 bg-gradient-to-br from-ayaba-terra/10 via-ayaba-cream to-ayaba-gold/10"></div>
                  )}
                </a>

                <div class="p-6 lg:p-8 flex flex-col flex-1">
                  {/* Tags */}
                  {post.data.tags.length > 0 && (
                    <div class="flex flex-wrap gap-2 mb-4">
                      {post.data.tags.slice(0, 3).map((tag, tagIdx) => (
                        <span class:list={[
                          'text-xs font-body font-medium px-2.5 py-1 rounded-full',
                          tagColors[tagIdx % tagColors.length],
                        ]}>
                          {tag}
                        </span>
                      ))}
                    </div>
                  )}

                  <h2 class="font-heading text-xl lg:text-[22px] text-ayaba-dark leading-snug mb-3">
                    <a href={`/fr/blog/${slug}/`} class="hover:text-ayaba-terra transition-colors">
                      {post.data.title}
                    </a>
                  </h2>

                  <p class="font-body text-sm text-ayaba-muted leading-relaxed mb-6 flex-1">
                    {post.data.description}
                  </p>

                  <div class="flex items-center justify-between pt-4 border-t border-gray-100">
                    <time class="text-xs text-ayaba-muted font-body" datetime={post.data.pubDate.toISOString()}>
                      {formattedDate}
                    </time>
                    <a
                      href={`/fr/blog/${slug}/`}
                      class="text-ayaba-terra font-body text-sm font-semibold hover:text-ayaba-terra/80 transition-colors inline-flex items-center gap-1"
                    >
                      {t(locale, 'blog.readMore')}
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                      </svg>
                    </a>
                  </div>
                </div>
              </article>
              {index === 4 && (
                <div class="md:col-span-2 lg:col-span-3 text-center py-6">
                  <p class="text-ayaba-muted text-sm mb-2">{t(locale, 'blog.inlineCta')}</p>
                  <a href="/#logements" class="text-ayaba-terra hover:text-ayaba-terra/80 font-semibold text-sm underline underline-offset-4 transition-colors">
                    {t(locale, 'blog.inlineCtaLink')} →
                  </a>
                </div>
              )}
            </>
          );
        })}
      </div>
    </div>
  </section>

  <FinalCta
    title={t(locale, 'blog.finalCtaTitle')}
    subtitle={t(locale, 'blog.finalCtaSubtitle')}
    ctaText={t(locale, 'blog.finalCtaCta')}
    ctaHref="/#logements"
  />
</BaseLayout>
