---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import LogementCards from '../components/sections/LogementCards.astro';
import ReviewsSection from '../components/sections/ReviewsSection.astro';
import FaqSection from '../components/sections/FaqSection.astro';
import FinalCta from '../components/sections/FinalCta.astro';
import PhotoLightbox from '../components/ui/PhotoLightbox.astro';
import SchemaOrg from '../components/seo/SchemaOrg.astro';
import { t } from '../i18n/utils';
import heroImage from '../assets/images/hero/salon.png';

const locale = 'fr' as const;
---
<BaseLayout
  locale={locale}
  title={t(locale, 'home.metaTitle')}
  description={t(locale, 'home.metaDescription')}
  hideHeader={true}
>
  <Fragment slot="head">
    <SchemaOrg type="LodgingBusiness" locale={locale} />
    <SchemaOrg type="WebSite" locale={locale} />
    <SchemaOrg type="SiteNavigationElement" locale={locale} />
  </Fragment>
  <HeroSection
    image={heroImage}
    imageAlt="Salon lumineux de Maison Ayaba a Fidjrosse, Cotonou"
    title={t(locale, 'home.heroTitle')}
    subtitle={t(locale, 'home.heroSubtitle')}
    primaryCta={{ text: t(locale, 'home.heroPrimaryCta'), href: '#logements' }}
  />

  <LogementCards locale={locale} />

  <ReviewsSection locale={locale} />

  <FaqSection locale={locale} />

  <FinalCta
    title={t(locale, 'home.finalCtaTitle')}
    subtitle={t(locale, 'home.finalCtaSubtitle')}
    ctaText={t(locale, 'home.finalCtaCta')}
    ctaHref="#logements"
  />

  <PhotoLightbox />
</BaseLayout>
