---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import ShowcaseSection from '../components/sections/ShowcaseSection.astro';
import LogementCards from '../components/sections/LogementCards.astro';
import ReviewsSection from '../components/sections/ReviewsSection.astro';
import FaqSection from '../components/sections/FaqSection.astro';
import FinalCta from '../components/sections/FinalCta.astro';
import SchemaOrg from '../components/seo/SchemaOrg.astro';
import { t } from '../i18n/utils';
import heroImage from '../assets/images/hero/salon.png';

const locale = 'fr' as const;
---
<BaseLayout
  locale={locale}
  title="Maison Ayaba — Logements meublés à Fidjrossè, Cotonou"
  description={t(locale, 'home.heroSubtitle')}
  hideHeader={true}
>
  <Fragment slot="head">
    <SchemaOrg type="LodgingBusiness" locale={locale} />
    <SchemaOrg type="WebSite" locale={locale} />
    <SchemaOrg type="SiteNavigationElement" locale={locale} />
  </Fragment>
  <HeroSection
    image={heroImage}
    imageAlt="Salon lumineux de Maison Ayaba a Fidjrosse, Cotonou"
    label={t(locale, 'home.heroLabel')}
    badge={t(locale, 'home.heroBadge')}
    title={t(locale, 'home.heroTitle')}
    subtitle={t(locale, 'home.heroSubtitle')}
    stats={[
      { value: t(locale, 'home.statPriceValue'), label: t(locale, 'home.statPriceLabel') },
      { value: t(locale, 'home.statConfigsValue'), label: t(locale, 'home.statConfigsLabel') },
      { value: t(locale, 'home.statGuestsValue'), label: t(locale, 'home.statGuestsLabel') },
      { value: t(locale, 'home.statBeachValue'), label: t(locale, 'home.statBeachLabel') },
    ]}
    primaryCta={{ text: t(locale, 'home.heroPrimaryCta'), href: '#logements' }}
    secondaryCta={{ text: t(locale, 'home.heroSecondaryCta'), href: '#photos' }}
  />

  <ShowcaseSection locale={locale} />

  <LogementCards locale={locale} />

  <ReviewsSection locale={locale} />

  <FaqSection locale={locale} />

  <FinalCta
    title={t(locale, 'home.finalCtaTitle')}
    subtitle={t(locale, 'home.finalCtaSubtitle')}
    ctaText={t(locale, 'home.finalCtaCta')}
    ctaHref="#logements"
  />
</BaseLayout>
