---
import { Image } from 'astro:assets';
import LineIcon from '../ui/LineIcon.astro';
import type { Locale } from '../../i18n/utils';
import salon from '../../assets/images/apartments/salon1.png';
import chambre from '../../assets/images/apartments/chambre1.png';
import sdb from '../../assets/images/apartments/chambre1-sdb.png';
import terrasse from '../../assets/images/apartments/terrasse1.png';

interface Props {
  locale: Locale;
  ctaHref: string;
  /** Liens Airbnb par format, dans l'ordre 1 / 2 / 3 chambres. */
  formatHrefs: string[];
}

const { locale, ctaHref, formatHrefs } = Astro.props;

const photos = [
  { src: salon, altFr: "Salon de l'appartement Maison Ayaba à Fidjrossè, Cotonou", altEn: 'Living room of the Maison Ayaba apartment in Fidjrossè, Cotonou' },
  { src: chambre, altFr: "Chambre de l'appartement Maison Ayaba à Fidjrossè, Cotonou", altEn: 'Bedroom of the Maison Ayaba apartment in Fidjrossè, Cotonou' },
  { src: sdb, altFr: "Salle de bain de l'appartement Maison Ayaba à Fidjrossè, Cotonou", altEn: 'Bathroom of the Maison Ayaba apartment in Fidjrossè, Cotonou' },
  { src: terrasse, altFr: "Terrasse de l'appartement Maison Ayaba à Fidjrossè, Cotonou", altEn: 'Terrace of the Maison Ayaba apartment in Fidjrossè, Cotonou' },
];

const content = {
  fr: {
    reassurance: ['5/5 sur Airbnb', 'Quartier sécurisé, gardien la nuit', 'Paiement protégé', 'Équipe sur place'],
    painTitle: "Première fois à Cotonou ? La vraie question, c'est la sécurité.",
    painP1: "Vous réservez de loin, peut-être pour votre premier séjour au Bénin. Les photos sont belles — mais le quartier est-il sûr ? L'endroit ressemble-t-il vraiment aux photos ? Et s'il y a un souci, y aura-t-il quelqu'un pour vous ?",
    painP2: 'Votre séjour est trop précieux pour le jouer à pile ou face.',
    solutionTitle: 'Tout est pensé pour que vous soyez tranquille.',
    solutions: [
      { icon: 'lock', lead: 'Un quartier sûr, un gardien la nuit', text: 'Zone résidentielle réputée, à deux pas du Lycée International Français. Serrure connectée et coffre-fort dans l’appartement.' },
      { icon: 'chat', lead: 'Une équipe sur place, qui répond', text: 'Nous sommes à Cotonou. Olivia, votre contact, joignable sur WhatsApp avant et pendant votre séjour.' },
      { icon: 'camera', lead: 'Conforme aux photos', text: 'Le logement que vous réservez est celui que vous trouvez. Photos réelles, rien de trafiqué — les avis le confirment.' },
      { icon: 'snowflake', lead: 'Un confort qui fonctionne vraiment', text: 'Climatisation dans chaque pièce, vérifiée avant chaque arrivée. Salle de bain par chambre, propre et prête.' },
      { icon: 'plane', lead: 'Une arrivée sans stress', text: 'Transfert aéroport offert, organisé avant votre venue. Check-in autonome avec votre code.' },
      { icon: 'shield', lead: 'Paiement protégé', text: 'Réservation via Airbnb : paiement sécurisé, avis vérifiés, assistance.' },
    ],
    secTitle: "Vous voyagez l'esprit léger, seule ou en famille",
    secText: "Maison Ayaba est dans l'un des quartiers les plus calmes et réputés de Cotonou, juste à côté du Lycée International Français Pierre Manoël Talon. Un gardien veille la nuit, l'accès se fait par serrure connectée (votre code personnel, pas de clé qui circule), et un coffre-fort sécurise vos affaires. Une équipe est sur place et joignable à tout moment.",
    transpTitle: 'Tout est dit à l’avance. Vraiment tout.',
    transpText: "Pas de frais caché, pas de surprise à la fin du séjour. Électricité incluse jusqu'à 25 kWh/jour — largement suffisant pour un usage normal, climatisation comprise. Au-delà, la consommation est facturée au réel, et c'est indiqué clairement avant votre réservation. Au Bénin, l'électricité a un coût réel : nous préférons être transparents plutôt que de gonfler le prix de la nuit.",
    proofTitle: "Ils ont réservé sans nous connaître. Voilà ce qu'ils en disent.",
    proofBadge: '7 avis vérifiés sur Airbnb',
    reviews: [
      { text: "Ma famille et moi avons apprécié notre séjour. Super propre, et on sent que les gestionnaires ont beaucoup réfléchi au confort des voyageurs : batteries externes dans les chambres, parapluies, tapis d'exercice, instructions des appareils… L'appartement est aussi à deux pas de la plage, la cerise sur le gâteau. Vivement recommandé.", author: 'Ore', meta: 'Lagos, Nigeria' },
      { text: "Logement extrêmement bien situé (10 min max de l'aéroport en voiture, toutes les commodités à moins de 10 min à pied), impeccable, avec une décoration épurée et des meubles valorisant le savoir-faire béninois. On se sent comme à la maison. Cet appartement dépasse très largement le niveau global des appartements proposés à Cotonou.", author: 'Frantz', meta: 'Paris, France' },
      { text: "Agréablement surpris de la qualité du logement et de la réactivité d'Olivia. La localisation le rend encore plus unique. La propreté, le cadre, tout était parfait.", author: 'Sefou', meta: 'Bruxelles, Belgique' },
      { text: "Séjour parfait du début à la fin ! Le logement était impeccable, confortable et conforme à la description. L'accueil, la disponibilité et l'attention portée aux détails ont vraiment fait la différence. Je recommande ce lieu à 100 %.", author: 'Laurette', meta: 'Appartement 3 chambres' },
      { text: 'Un espace magnifique et accueillant. Bien pensé, confortable et relaxant. Olivia a été aimable, réactive et très attentionnée. Hautement recommandé !', author: 'Olutayo', meta: 'Lagos, Nigeria' },
      { text: "J'ai été agréablement surpris par le logement. Tout était impeccable. J'ai passé un très bon séjour.", author: 'Muriel', meta: 'Ploeren, France' },
      { text: "Maison Ayaba, j'ai hâte de réserver à nouveau chez vous pour mon prochain voyage !", author: 'Ayigbe', meta: 'Accra, Ghana' },
    ],
    offerTitle: "Votre appartement à Fidjrossè, jusqu'à 6 voyageurs",
    offerLead: 'Choisissez votre format : chacun sa chambre, chacun sa salle de bain. À plusieurs, le coût par personne devient imbattable.',
    perNight: 'nuit',
    offerPriceNote: 'selon les dates',
    formats: [
      { name: '1 chambre', capacity: '1 à 2 voyageurs', price: 'dès 30 €', use: 'En solo ou en couple — tout l’espace rien que pour vous.' },
      { name: '2 chambres', capacity: '3 à 4 voyageurs', price: 'dès 40 €', use: 'Couple avec invités ou petite famille. Chacun sa salle de bain.' },
      { name: '3 chambres', capacity: '5 à 6 voyageurs', price: 'dès 50 €', use: 'Famille nombreuse ou groupe d’amis. Trois chambres, trois salles de bain.' },
    ],
    offerCta: 'Réserver sur Airbnb',
    offerNote: "Paiement protégé · Annulation selon les conditions de l'annonce",
    locTitle: 'Fidjrossè — quartier sûr, bord de mer',
    locText: "À deux pas du Lycée International Français, à 10 minutes à pied de la plage et à ~20 minutes de l'aéroport. Un quartier résidentiel calme, prisé des familles et des expatriés.",
    finalTitle: "Rentrez au pays l'esprit tranquille",
    finalText: 'Réservez votre appartement à Cotonou — paiement protégé, avis vérifiés, équipe sur place.',
    finalCta: 'Réserver sur Airbnb',
    finalMicro: 'Paiement protégé par Airbnb · 5/5 sur les avis voyageurs',
    faqTitle: 'Questions fréquentes',
    faq: [
      { q: 'Comment être sûr que le logement ressemble aux photos ?', a: "Avis 5/5 de voyageurs réels et photos non retouchées. Et avec le paiement protégé Airbnb, vous n'êtes jamais seul en cas de souci." },
      { q: 'Vais-je partager le logement ?', a: "Non. L'appartement est à vous seul." },
      { q: 'Êtes-vous joignables une fois sur place ?', a: 'Oui — nous sommes à Cotonou. Olivia, votre contact, répond sur WhatsApp avant et pendant votre séjour.' },
      { q: 'Et si le courant saute ?', a: "Le WiFi reste actif grâce à un onduleur dédié. La lumière et la clim s'arrêtent le temps de la coupure." },
      { q: 'Comment réserver ?', a: "En un clic vers l'annonce Airbnb : paiement protégé, avis vérifiés." },
    ],
  },
  en: {
    reassurance: ['5/5 on Airbnb', 'Safe neighborhood, night guard', 'Protected payment', 'On-site team'],
    painTitle: 'First time in Cotonou? The real question is safety.',
    painP1: "You're booking from afar, perhaps for your first stay in Benin. The photos look great — but is the neighborhood safe? Does the place really look like the photos? And if something goes wrong, will someone be there for you?",
    painP2: 'Your stay is too precious to leave to chance.',
    solutionTitle: 'Everything is designed to put you at ease.',
    solutions: [
      { icon: 'lock', lead: 'A safe neighborhood, a night guard', text: 'A well-regarded residential area, steps from the Lycée International Français. Smart lock and a safe in the apartment.' },
      { icon: 'chat', lead: 'An on-site team that answers', text: "We're in Cotonou. Olivia, your contact, reachable on WhatsApp before and during your stay." },
      { icon: 'camera', lead: 'True to the photos', text: 'The apartment you book is the one you find. Real photos, nothing doctored — the reviews confirm it.' },
      { icon: 'snowflake', lead: 'Comfort that actually works', text: 'Air conditioning in every room, checked before each arrival. A bathroom per bedroom, clean and ready.' },
      { icon: 'plane', lead: 'A stress-free arrival', text: 'Complimentary airport transfer, arranged before you come. Self check-in with your code.' },
      { icon: 'shield', lead: 'Protected payment', text: 'Booking via Airbnb: secure payment, verified reviews, support.' },
    ],
    secTitle: 'You travel with peace of mind, solo or with family',
    secText: 'Maison Ayaba sits in one of the calmest, most well-regarded neighborhoods in Cotonou, right next to the Lycée International Français Pierre Manoël Talon. A guard watches over the night, access is by smart lock (your personal code, no keys passed around), and a safe secures your belongings. A team is on site and reachable at any time.',
    transpTitle: 'Everything is stated upfront. Truly everything.',
    transpText: "No hidden fees, no surprise at the end of your stay. Electricity included up to 25 kWh/day — more than enough for normal use, air conditioning included. Beyond that, consumption is billed at actual cost, and it's stated clearly before you book. In Benin, electricity has a real cost: we'd rather be transparent than inflate the nightly price.",
    proofTitle: "They booked without knowing us. Here's what they say.",
    proofBadge: '7 verified reviews on Airbnb',
    reviews: [
      { text: "My family and I really enjoyed our stay. Super clean, and you can tell the hosts put a lot of thought into guests' comfort: power banks in the bedrooms, umbrellas, exercise mats, appliance instructions… The apartment is also a stone's throw from the beach, the icing on the cake. Highly recommended.", author: 'Ore', meta: 'Lagos, Nigeria' },
      { text: 'Exceptionally well located (10 min max from the airport by car, every amenity within a 10-minute walk), spotless, with understated decor and furniture that showcases Beninese craftsmanship. You feel right at home. This apartment is well above the general standard of apartments offered in Cotonou.', author: 'Frantz', meta: 'Paris, France' },
      { text: "Pleasantly surprised by the quality of the accommodation and Olivia's responsiveness. The location makes it even more unique. Cleanliness, setting, everything was perfect.", author: 'Sefou', meta: 'Brussels, Belgium' },
      { text: 'A perfect stay from start to finish! The apartment was spotless, comfortable and exactly as described. The welcome, the availability and the attention to detail really made the difference. I recommend this place 100%.', author: 'Laurette', meta: '3-bedroom apartment' },
      { text: 'A beautiful and welcoming space. Well thought out, comfortable and relaxing. Olivia was kind, responsive and very attentive. Highly recommended!', author: 'Olutayo', meta: 'Lagos, Nigeria' },
      { text: 'I was pleasantly surprised by the place. Everything was spotless. I had a very good stay.', author: 'Muriel', meta: 'Ploeren, France' },
      { text: "Maison Ayaba, I can't wait to book with you again for my next trip!", author: 'Ayigbe', meta: 'Accra, Ghana' },
    ],
    offerTitle: 'Your apartment in Fidjrossè, up to 6 guests',
    offerLead: 'Choose your format: everyone gets their own bedroom, their own bathroom. The more of you, the more unbeatable the cost per person.',
    perNight: 'night',
    offerPriceNote: 'based on dates',
    formats: [
      { name: '1 bedroom', capacity: '1–2 guests', price: 'from €30', use: 'Solo or as a couple — all the space to yourself.' },
      { name: '2 bedrooms', capacity: '3–4 guests', price: 'from €40', use: 'Couple with guests or a small family. Each their own bathroom.' },
      { name: '3 bedrooms', capacity: '5–6 guests', price: 'from €50', use: 'Large family or group of friends. Three bedrooms, three bathrooms.' },
    ],
    offerCta: 'Book on Airbnb',
    offerNote: "Protected payment · Cancellation per the listing's terms",
    locTitle: 'Fidjrossè — safe neighborhood, by the sea',
    locText: 'Steps from the Lycée International Français, a 10-minute walk from the beach and about 20 minutes from the airport. A calm residential area, popular with families and expats.',
    finalTitle: 'Go home with peace of mind',
    finalText: 'Book your apartment in Cotonou — protected payment, verified reviews, on-site team.',
    finalCta: 'Book on Airbnb',
    finalMicro: 'Payment protected by Airbnb · 5/5 on traveler reviews',
    faqTitle: 'Frequently asked questions',
    faq: [
      { q: 'How can I be sure the place looks like the photos?', a: "5/5 reviews from real travelers and unretouched photos. And with Airbnb's protected payment, you're never on your own if something comes up." },
      { q: 'Will I share the apartment?', a: 'No. The apartment is yours alone.' },
      { q: "Are you reachable once I'm there?", a: 'Yes — we’re in Cotonou. Olivia, your contact, answers on WhatsApp before and during your stay.' },
      { q: 'What if the power goes out?', a: 'The WiFi stays on thanks to a dedicated inverter. The lights and AC stop for the duration of the outage.' },
      { q: 'How do I book?', a: 'One click to the Airbnb listing: protected payment, verified reviews.' },
    ],
  },
} as const;

const c = content[locale];
const arrow = '<path fill-rule="evenodd" d="M5.22 14.78a.75.75 0 001.06 0l7.22-7.22v5.69a.75.75 0 001.5 0v-7.5a.75.75 0 00-.75-.75h-7.5a.75.75 0 000 1.5h5.69l-7.22 7.22a.75.75 0 000 1.06z" clip-rule="evenodd"/>';
---
{/* Bandeau réassurance */}
<section class="bg-ayaba-dark text-white">
  <div class="max-w-6xl mx-auto px-5 lg:px-8 py-3.5">
    <ul class="flex flex-wrap items-center justify-center gap-x-3 gap-y-1.5 text-[12px] lg:text-sm">
      {c.reassurance.map((item, i) => (
        <li class="flex items-center gap-3">
          {i > 0 && <span class="text-ayaba-gold/60" aria-hidden="true">·</span>}
          <span class="flex items-center gap-1.5"><LineIcon name="check" class="w-3.5 h-3.5 text-ayaba-gold shrink-0" />{item}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

{/* La douleur */}
<section class="bg-white py-16 lg:py-20">
  <div class="max-w-3xl mx-auto px-5 lg:px-8">
    <h2 class="font-heading text-ayaba-dark text-[26px] lg:text-[34px] font-bold mb-6 leading-tight">{c.painTitle}</h2>
    <p class="text-ayaba-muted text-base lg:text-lg leading-relaxed mb-4">{c.painP1}</p>
    <p class="text-ayaba-dark text-base lg:text-lg leading-relaxed font-semibold">{c.painP2}</p>
  </div>
</section>

{/* La solution */}
<section class="bg-ayaba-cream py-16 lg:py-20">
  <div class="max-w-5xl mx-auto px-5 lg:px-8">
    <h2 class="font-heading text-ayaba-dark text-[26px] lg:text-[34px] font-bold mb-10 lg:mb-12 text-center max-w-2xl mx-auto leading-tight">{c.solutionTitle}</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-10 gap-y-7">
      {c.solutions.map((s) => (
        <div class="flex items-start gap-4">
          <span class="w-11 h-11 rounded-full bg-white border border-ayaba-terra/15 flex items-center justify-center shrink-0">
            <LineIcon name={s.icon} class="w-5 h-5 text-ayaba-terra" />
          </span>
          <div>
            <h3 class="font-semibold text-ayaba-dark text-base lg:text-[17px] mb-1">{s.lead}</h3>
            <p class="text-ayaba-muted text-sm lg:text-base leading-relaxed">{s.text}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

{/* Sécurité — bloc dédié */}
<section class="bg-white py-16 lg:py-20">
  <div class="max-w-3xl mx-auto px-5 lg:px-8 text-center">
    <span class="w-12 h-12 rounded-full bg-ayaba-cream border border-ayaba-terra/15 flex items-center justify-center mx-auto mb-5">
      <LineIcon name="shield" class="w-5 h-5 text-ayaba-terra" />
    </span>
    <h2 class="font-heading text-ayaba-dark text-[24px] lg:text-[32px] font-bold mb-4 leading-tight">{c.secTitle}</h2>
    <p class="text-ayaba-muted text-base lg:text-lg leading-relaxed">{c.secText}</p>
  </div>
</section>

{/* Vraies photos de l'appartement */}
<section class="bg-ayaba-cream py-16 lg:py-20">
  <div class="max-w-6xl mx-auto px-5 lg:px-8">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 lg:gap-4">
      {photos.map((p) => (
        <div class="rounded-xl overflow-hidden aspect-[4/3] bg-ayaba-cream">
          <Image src={p.src} alt={locale === 'fr' ? p.altFr : p.altEn} widths={[280, 480]} sizes="(min-width:1024px) 280px, 45vw" class="w-full h-full object-cover" loading="lazy" />
        </div>
      ))}
    </div>
  </div>
</section>

{/* Preuve */}
<section class="bg-white py-16 lg:py-20">
  <div class="max-w-4xl mx-auto px-5 lg:px-8">
    <h2 class="font-heading text-ayaba-dark text-[24px] lg:text-[32px] font-bold mb-3 text-center leading-tight">{c.proofTitle}</h2>
    <p class="flex items-center justify-center gap-2 mb-10 text-center">
      <span class="text-ayaba-gold text-lg" aria-hidden="true">★★★★★</span>
      <span class="text-ayaba-dark text-sm font-semibold">5/5 · {c.proofBadge}</span>
    </p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-start">
      {c.reviews.map((r) => (
        <figure class="bg-ayaba-cream rounded-2xl p-6 lg:p-7 flex flex-col">
          <div class="text-ayaba-gold text-lg mb-3" aria-hidden="true">★★★★★</div>
          <blockquote class="text-ayaba-dark text-base leading-relaxed mb-4 flex-1">« {r.text} »</blockquote>
          <figcaption class="text-ayaba-muted text-sm font-semibold">— {r.author} <span class="font-normal text-ayaba-muted/80">· {r.meta}</span></figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

{/* Transparence — bloc dédié */}
<section class="bg-ayaba-cream py-16 lg:py-20">
  <div class="max-w-3xl mx-auto px-5 lg:px-8 text-center">
    <span class="w-12 h-12 rounded-full bg-white border border-ayaba-terra/15 flex items-center justify-center mx-auto mb-5">
      <LineIcon name="check" class="w-5 h-5 text-ayaba-terra" />
    </span>
    <h2 class="font-heading text-ayaba-dark text-[24px] lg:text-[32px] font-bold mb-4 leading-tight">{c.transpTitle}</h2>
    <p class="text-ayaba-muted text-base lg:text-lg leading-relaxed">{c.transpText}</p>
  </div>
</section>

{/* L'offre — 3 formats, un lien par annonce */}
<section class="bg-white py-16 lg:py-20">
  <div class="max-w-5xl mx-auto px-5 lg:px-8 text-center">
    <h2 class="font-heading text-ayaba-dark text-[26px] lg:text-[34px] font-bold mb-3 leading-tight">{c.offerTitle}</h2>
    <p class="text-ayaba-muted text-base lg:text-lg leading-relaxed mb-10 max-w-2xl mx-auto">{c.offerLead}</p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 lg:gap-6">
      {c.formats.map((f, i) => (
        <div class="bg-ayaba-cream rounded-2xl p-6 lg:p-7 border border-ayaba-terra/15 flex flex-col items-center text-center">
          <h3 class="font-heading text-ayaba-dark text-[20px] font-bold mb-1">{f.name}</h3>
          <p class="text-ayaba-muted text-sm mb-4">{f.capacity}</p>
          <div class="mb-4">
            <span class="font-heading text-ayaba-terra text-[28px] font-bold">{f.price}</span>
            <span class="text-ayaba-muted text-sm"> /{c.perNight}</span>
            <p class="text-ayaba-muted text-xs mt-0.5">{c.offerPriceNote}</p>
          </div>
          <p class="text-ayaba-dark text-sm mb-6 leading-relaxed flex-1">{f.use}</p>
          <a
            href={formatHrefs[i]}
            target="_blank"
            rel="noopener"
            data-airbnb-cta
            class="bg-ayaba-terra text-white hover:bg-ayaba-terra/90 rounded-md px-6 py-3.5 w-full font-semibold text-[15px] inline-flex items-center justify-center gap-2 min-h-[48px] transition-colors mt-auto focus:outline-2 focus:outline-offset-2 focus:outline-ayaba-terra"
          >
            {c.offerCta}
            <svg class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" set:html={arrow}></svg>
          </a>
        </div>
      ))}
    </div>
    <p class="text-ayaba-muted text-xs mt-6">{c.offerNote}</p>
  </div>
</section>

{/* Localisation */}
<section class="bg-ayaba-cream py-16 lg:py-20">
  <div class="max-w-3xl mx-auto px-5 lg:px-8 text-center">
    <span class="w-12 h-12 rounded-full bg-white border border-ayaba-terra/15 flex items-center justify-center mx-auto mb-5">
      <LineIcon name="pin" class="w-5 h-5 text-ayaba-terra" />
    </span>
    <h2 class="font-heading text-ayaba-dark text-[24px] lg:text-[32px] font-bold mb-4 leading-tight">{c.locTitle}</h2>
    <p class="text-ayaba-muted text-base lg:text-lg leading-relaxed">{c.locText}</p>
  </div>
</section>

{/* CTA final */}
<section class="bg-ayaba-dark py-16 lg:py-20">
  <div class="max-w-2xl mx-auto px-5 lg:px-8 text-center">
    <h2 class="font-heading text-white text-[26px] lg:text-[34px] font-bold mb-4 leading-tight">{c.finalTitle}</h2>
    <p class="text-white/70 text-base lg:text-lg mb-8 leading-relaxed">{c.finalText}</p>
    <a
      href={ctaHref}
      target="_blank"
      rel="noopener"
      data-airbnb-cta
      class="bg-ayaba-terra text-white hover:bg-ayaba-terra/90 rounded-md px-8 py-4 font-semibold text-base lg:text-lg transition-colors min-h-[52px] inline-flex items-center gap-2 shadow-lg focus:outline-2 focus:outline-offset-2 focus:outline-white"
    >
      {c.finalCta}
      <svg class="w-5 h-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" set:html={arrow}></svg>
    </a>
    <p class="flex items-center justify-center gap-2 text-white/60 text-xs lg:text-sm mt-4">
      <LineIcon name="shield" class="w-4 h-4 text-ayaba-gold shrink-0" />
      {c.finalMicro}
    </p>
  </div>
</section>

{/* FAQ courte */}
<section class="bg-white py-16 lg:py-20">
  <div class="max-w-2xl mx-auto px-5 lg:px-8">
    <h2 class="font-heading text-ayaba-dark text-[24px] lg:text-[30px] font-bold mb-8 text-center">{c.faqTitle}</h2>
    <div class="space-y-3">
      {c.faq.map((item) => (
        <details class="bg-ayaba-cream rounded-xl border border-gray-100 overflow-hidden group">
          <summary class="px-5 py-4 cursor-pointer font-semibold text-ayaba-dark text-sm lg:text-base flex items-center justify-between gap-4 min-h-[44px]">
            {item.q}
            <span class="text-ayaba-terra shrink-0 transition-transform group-open:rotate-45 text-lg" aria-hidden="true">+</span>
          </summary>
          <div class="px-5 pb-4 text-ayaba-muted text-sm lg:text-base leading-relaxed">{item.a}</div>
        </details>
      ))}
    </div>
  </div>
</section>
