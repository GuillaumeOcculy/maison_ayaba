---
import { t, type Locale } from '../../i18n/utils';
import { apartments } from '../../data/apartments';

interface Props {
  configId: '1ch' | '2ch' | '3ch';
  variant?: 'primary' | 'outline';
  size?: 'default' | 'large';
  label?: string;
  locale: Locale;
}

const { configId, variant = 'primary', size = 'default', label, locale } = Astro.props;

const configMap: Record<string, number> = { '1ch': 0, '2ch': 1, '3ch': 2 };
const apartment = apartments[configMap[configId]];
const airbnbUrl = apartment.airbnbUrl;

const defaultLabel = t(locale, 'nav.book');
const buttonLabel = label ?? defaultLabel;

const baseClasses = 'inline-flex items-center justify-center min-h-[44px] font-body font-semibold text-sm transition-colors focus:outline-2 focus:outline-offset-2 focus:outline-ayaba-terra';

const variantClasses = variant === 'primary'
  ? 'bg-ayaba-terra text-white hover:bg-ayaba-terra/90 rounded-md'
  : 'border-2 border-ayaba-terra text-ayaba-terra hover:bg-ayaba-terra hover:text-white rounded-full';

const sizeClasses = size === 'large' ? 'px-6 py-3 text-base' : 'px-4 py-2';

const classes = `${baseClasses} ${variantClasses} ${sizeClasses}`;
---
<a
  href={airbnbUrl}
  target="_blank"
  rel="noopener noreferrer"
  class={classes}
  aria-label={`${buttonLabel} — ${apartment.name}`}
  data-airbnb-cta
  data-config-id={configId}
>
  {buttonLabel}
</a>

<script>
  document.querySelectorAll('[data-airbnb-cta]').forEach((cta) => {
    cta.addEventListener('click', () => {
      if (typeof gtag !== 'undefined') {
        gtag('event', 'airbnb_click', {
          config: (cta as HTMLElement).dataset.configId,
          page: window.location.pathname,
        });
      }
    });
  });
</script>
