---
// Terracotta line-icon set (stroke, currentColor). Replaces emojis across the site.
// Usage: <LineIcon name="utensils" class="w-6 h-6 text-ayaba-terra" />
interface Props {
  name: string;
  class?: string;
}

const { name, class: className = 'w-6 h-6 text-ayaba-terra' } = Astro.props;

const paths: Record<string, string> = {
  utensils: '<path d="M4 3v6a2 2 0 002 2h0v10M8 3v8M6 3v8M16 3c-1.5 0-2.5 2-2.5 5s1 4 2.5 4v9"/>',
  bag: '<path d="M6 8h12l-1 12H7L6 8z"/><path d="M9 8V6a3 3 0 016 0v2"/>',
  sun: '<circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/>',
  pin: '<path d="M12 21s-7-5.5-7-11a7 7 0 0114 0c0 5.5-7 11-7 11z"/><circle cx="12" cy="10" r="2.5"/>',
  car: '<path d="M5 16v2a1 1 0 01-1 1H3M19 16v2a1 1 0 001 1h1M4 16l1.5-6h13L20 16M4 16h16v-3H4v3z"/><circle cx="7.5" cy="16" r="0"/><path d="M7 13h.01M17 13h.01"/>',
  shield: '<path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6l7-3z"/><path d="M9 12l2 2 4-4"/>',
  chat: '<path d="M21 12a8 8 0 01-11.5 7.2L4 20l1-4.2A8 8 0 1121 12z"/>',
  camera: '<path d="M4 8h3l1.5-2h7L17 8h3a1 1 0 011 1v9a1 1 0 01-1 1H4a1 1 0 01-1-1V9a1 1 0 011-1z"/><circle cx="12" cy="13" r="3.5"/>',
  snowflake: '<path d="M12 2v20M4 6l16 12M20 6L4 18M5 9l14 6M19 9L5 15"/>',
  plane: '<path d="M10.5 19l1.5-5 7-3.5a1.5 1.5 0 000-2.8L4 2l3 7-3 3 3 1 1 3 2.5-2z"/>',
  lock: '<rect x="5" y="10" width="14" height="10" rx="2"/><path d="M8 10V7a4 4 0 018 0v3"/>',
  wave: '<path d="M3 12c1.5-2 3-2 4.5 0s3 2 4.5 0 3-2 4.5 0 3 2 4.5 0M3 17c1.5-2 3-2 4.5 0s3 2 4.5 0 3-2 4.5 0 3 2 4.5 0"/>',
  check: '<circle cx="12" cy="12" r="9"/><path d="M8 12l2.5 2.5L16 9"/>',
  star: '<path d="M12 3l2.6 5.3 5.9.9-4.3 4.1 1 5.8L12 16.9 6.8 19.2l1-5.8L3.5 9.2l5.9-.9L12 3z"/>',
};

const path = paths[name] ?? paths.check;
---
<svg
  class={className}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.6"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  set:html={path}
></svg>
