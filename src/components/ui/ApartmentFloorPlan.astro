---
import { t, type Locale } from '../../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<div class="w-full max-w-xl mx-auto mt-6">
  <svg viewBox="0 0 520 340" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label={t(locale, 'apartment.floorPlanAlt')} class="w-full h-auto">
    {/* Contour global de l'appartement */}
    <rect x="10" y="10" width="500" height="320" rx="12" stroke="#C8A45C" stroke-width="2.5" stroke-dasharray="8 4" fill="#FAF7F2" />

    {/* Label global */}
    <rect x="160" y="0" width="200" height="24" rx="12" fill="#C8A45C" />
    <text x="260" y="16" text-anchor="middle" font-size="11" font-weight="600" fill="white" font-family="Inter, system-ui, sans-serif">{t(locale, 'apartment.floorPlanLabel')}</text>

    {/* Salon */}
    <rect x="26" y="30" width="200" height="130" rx="8" fill="white" stroke="#A0522D" stroke-width="1.5" />
    <text x="126" y="90" text-anchor="middle" font-size="13" font-weight="600" fill="#2C1810" font-family="Inter, system-ui, sans-serif">{t(locale, 'apartment.floorPlanLiving')}</text>
    <text x="126" y="108" text-anchor="middle" font-size="10" fill="#6B5E57" font-family="Inter, system-ui, sans-serif">TV · Wi-Fi</text>

    {/* Cuisine */}
    <rect x="26" y="176" width="200" height="70" rx="8" fill="white" stroke="#A0522D" stroke-width="1.5" />
    <text x="126" y="216" text-anchor="middle" font-size="13" font-weight="600" fill="#2C1810" font-family="Inter, system-ui, sans-serif">{t(locale, 'apartment.floorPlanKitchen')}</text>

    {/* Terrasse */}
    <rect x="26" y="262" width="200" height="52" rx="8" fill="white" stroke="#A0522D" stroke-width="1.5" stroke-dasharray="5 3" />
    <text x="126" y="293" text-anchor="middle" font-size="13" font-weight="600" fill="#2C1810" font-family="Inter, system-ui, sans-serif">{t(locale, 'apartment.floorPlanTerrace')}</text>

    {/* Chambre 1 */}
    <rect x="244" y="30" width="120" height="90" rx="8" fill="white" stroke="#5A7247" stroke-width="1.5" />
    <text x="304" y="68" text-anchor="middle" font-size="12" font-weight="600" fill="#2C1810" font-family="Inter, system-ui, sans-serif">{t(locale, 'apartment.floorPlanBed1')}</text>
    <text x="304" y="84" text-anchor="middle" font-size="9" fill="#6B5E57" font-family="Inter, system-ui, sans-serif">+ {t(locale, 'apartment.floorPlanBathroom')}</text>

    {/* Chambre 2 */}
    <rect x="380" y="30" width="120" height="90" rx="8" fill="white" stroke="#5A7247" stroke-width="1.5" />
    <text x="440" y="68" text-anchor="middle" font-size="12" font-weight="600" fill="#2C1810" font-family="Inter, system-ui, sans-serif">{t(locale, 'apartment.floorPlanBed2')}</text>
    <text x="440" y="84" text-anchor="middle" font-size="9" fill="#6B5E57" font-family="Inter, system-ui, sans-serif">+ {t(locale, 'apartment.floorPlanBathroom')}</text>

    {/* Chambre 3 */}
    <rect x="244" y="136" width="256" height="90" rx="8" fill="white" stroke="#5A7247" stroke-width="1.5" />
    <text x="372" y="174" text-anchor="middle" font-size="12" font-weight="600" fill="#2C1810" font-family="Inter, system-ui, sans-serif">{t(locale, 'apartment.floorPlanBed3')}</text>
    <text x="372" y="190" text-anchor="middle" font-size="9" fill="#6B5E57" font-family="Inter, system-ui, sans-serif">+ {t(locale, 'apartment.floorPlanBathroom')}</text>

    {/* Légende en bas */}
    <rect x="244" y="248" width="256" height="66" rx="8" fill="#A0522D" fill-opacity="0.08" />
    <text x="372" y="274" text-anchor="middle" font-size="11" font-weight="600" fill="#A0522D" font-family="Inter, system-ui, sans-serif">{t(locale, 'apartment.floorPlanNote1')}</text>
    <text x="372" y="294" text-anchor="middle" font-size="10" fill="#6B5E57" font-family="Inter, system-ui, sans-serif">{t(locale, 'apartment.floorPlanNote2')}</text>
  </svg>
</div>
