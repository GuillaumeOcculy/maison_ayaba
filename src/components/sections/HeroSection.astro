---
import { Image } from 'astro:assets';

interface StatItem {
  value: string;
  label: string;
  oldPrice?: string;
  promoBadge?: string;
}

interface CtaLink {
  text: string;
  href: string;
}

interface Props {
  image?: ImageMetadata;
  imageAlt: string;
  badge?: string;
  label?: string;
  title: string;
  subtitle: string;
  stats?: StatItem[];
  primaryCta: CtaLink;
  secondaryCta?: CtaLink;
}

const { image, imageAlt, badge, label, title, subtitle, stats, primaryCta, secondaryCta } = Astro.props;
---
<section class="relative h-svh lg:h-[80vh] overflow-hidden">
  {image ? (
    <Image
      src={image}
      alt={imageAlt}
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      widths={[640, 1024, 1920]}
      sizes="100vw"
    />
  ) : (
    <div class="absolute inset-0 bg-ayaba-dark" role="img" aria-label={imageAlt}>
      <!-- TODO: remplacer par Image d'Astro quand les photos seront pretes -->
    </div>
  )}

  <div
    class="absolute inset-0"
    style="background: linear-gradient(180deg, rgba(44,24,16,0.10) 0%, rgba(44,24,16,0.50) 60%, rgba(44,24,16,0.75) 100%)"
    aria-hidden="true"
  ></div>

  <div class="relative h-full flex flex-col justify-end px-6 pb-10 lg:px-16 lg:pb-16 max-w-7xl mx-auto">
    {label && (
      <p class="text-white/60 text-xs uppercase tracking-[1.5px] font-semibold mb-4">
        {label}
      </p>
    )}

    {badge && (
      <span class="inline-flex items-center gap-1.5 bg-ayaba-cream/95 border border-ayaba-gold/30 text-ayaba-dark text-sm font-semibold px-4 py-1.5 rounded-full mb-4 w-fit">
        <svg class="w-4 h-4 shrink-0" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z" /></svg>
        {badge}
      </span>
    )}

    <h1 class="text-white font-heading text-[28px] lg:text-[48px] font-bold leading-tight max-w-2xl mb-3">
      {title}
    </h1>

    <p class="text-white/70 font-body text-base lg:text-lg max-w-xl mb-8">
      {subtitle}
    </p>

    {stats && stats.length > 0 && (
      <dl class="grid grid-cols-2 lg:flex lg:flex-row items-baseline gap-4 lg:gap-8 mb-8">
        {stats.map((stat) => (
          <div class:list={["relative flex flex-col", stat.promoBadge && "mr-16"]}>
            <dt class="text-ayaba-gold font-heading text-2xl font-bold flex items-baseline gap-2">
              {stat.value}
              {stat.oldPrice && (
                <span class="text-white/40 text-3xl line-through">{stat.oldPrice}</span>
              )}
            </dt>
            {stat.promoBadge && (
              <span class="absolute left-[calc(100%+8px)] top-1/2 -translate-y-1/2 bg-ayaba-terra text-white text-[7px] uppercase leading-none tracking-wide w-14 h-14 rounded-full font-semibold flex items-center justify-center text-center p-1">{stat.promoBadge}</span>
            )}
            <dd class="text-white/60 text-[11px] uppercase tracking-[1.5px]">
              {stat.label}
            </dd>
          </div>
        ))}
      </dl>
    )}

    <div class="flex flex-wrap gap-3">
      <a
        href={primaryCta.href}
        class="bg-ayaba-terra text-white hover:bg-ayaba-terra/90 rounded-md px-6 py-3 font-body font-semibold min-h-[44px] inline-flex items-center focus:outline-2 focus:outline-offset-2 focus:outline-ayaba-terra transition-colors"
      >
        {primaryCta.text}
      </a>
      {secondaryCta && (
        <a
          href={secondaryCta.href}
          class="border border-white/30 text-white hover:bg-white/10 rounded-md px-6 py-3 font-body min-h-[44px] inline-flex items-center focus:outline-2 focus:outline-offset-2 focus:outline-ayaba-terra transition-colors"
        >
          {secondaryCta.text}
        </a>
      )}
    </div>
  </div>
</section>
