---
interface TransportMode {
  name: string;
  description: string;
  price: string;
  tip?: string;
}

interface Props {
  title: string;
  description?: string;
  modes: TransportMode[];
  bgClass?: string;
}

const { title, description, modes, bgClass = 'bg-ayaba-cream' } = Astro.props;
---
<section class={`${bgClass} py-16 lg:py-20`}>
  <div class="max-w-[800px] mx-auto px-6 lg:px-16">
    <div class="text-center mb-10">
      <span class="text-3xl mb-3 block" aria-hidden="true">🚗</span>
      <h2 class="font-heading text-ayaba-dark text-[26px] lg:text-[32px] font-bold mb-3">
        {title}
      </h2>
      {description && (
        <p class="text-ayaba-muted text-base max-w-2xl mx-auto">
          {description}
        </p>
      )}
    </div>

    <div class="space-y-6">
      {modes.map((mode) => (
        <div class="bg-white rounded-lg p-5 shadow-sm">
          <h3 class="font-heading text-ayaba-dark text-lg font-bold mb-2">
            {mode.name}
          </h3>
          <p class="text-ayaba-muted text-sm mb-3">
            {mode.description}
          </p>
          <div class="flex items-center gap-2 mb-2">
            <span class="text-ayaba-terra font-semibold text-sm">
              {mode.price}
            </span>
          </div>
          {mode.tip && (
            <p class="text-ayaba-success text-sm flex items-start gap-2">
              <span class="shrink-0 font-bold" aria-hidden="true">&#10003;</span>
              {mode.tip}
            </p>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
