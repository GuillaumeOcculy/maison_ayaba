---
import ImageGallery from '../ui/ImageGallery.astro';
import AirbnbCta from '../ui/AirbnbCta.astro';
import { t, type Locale } from '../../i18n/utils';
import type { ApartmentConfig } from '../../data/apartments';

const nameKeys = ['home.config1chName', 'home.config2chName', 'home.config3chName'];
const configSlugs = ['1-chambre', '2-chambres', '3-chambres'];

interface Props {
  apartment: ApartmentConfig;
  images: { src: ImageMetadata; alt: string }[];
  locale: Locale;
  description: string;
  pricePerPerson?: string;
  bgClass?: string;
}

const { apartment, images, locale, description, pricePerPerson, bgClass = 'bg-white' } = Astro.props;

const configId = `${apartment.slug.replace('-chambres', 'ch').replace('-chambre', 'ch')}` as '1ch' | '2ch' | '3ch';
const configIndex = configSlugs.indexOf(apartment.slug);
const displayName = configIndex >= 0 ? t(locale, nameKeys[configIndex]) : apartment.name;
const subtitleKeys = ['home.config1chSubtitle', 'home.config2chSubtitle', 'home.config3chSubtitle'];
const subtitle = configIndex >= 0 ? t(locale, subtitleKeys[configIndex]) : '';
const priceRange = t(locale, 'apartment.priceRange', { min: String(apartment.pricePerNight.min), max: String(apartment.pricePerNight.max) });
const bonuses = [
  t(locale, 'home.bonusWelcomeBasket'),
  t(locale, 'home.bonusCleaning'),
  t(locale, 'home.bonusConcierge'),
  t(locale, 'home.bonusTransfer'),
];
---
<section class:list={[bgClass, 'py-16 lg:py-20']}>
  <div class="max-w-[1200px] mx-auto px-6 lg:px-16">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-14 items-start">
      {/* Gallery */}
      <div>
        <ImageGallery images={images} configName={apartment.name} locale={locale} />
      </div>

      {/* Details */}
      <div>
        <h2 class="font-heading text-ayaba-dark text-[26px] lg:text-[32px] font-bold mb-2">
          {displayName}
        </h2>

        <p class="text-ayaba-muted text-sm mb-4">{subtitle}</p>

        <p class="text-ayaba-dark text-base leading-relaxed mb-6">
          {description}
        </p>

        {/* Price */}
        <div class="mb-6">
          <span class="text-ayaba-terra text-[28px] lg:text-[32px] font-bold">{priceRange}</span>
          <span class="text-ayaba-muted text-sm ml-1">{t(locale, 'labels.perNight')}</span>
          {pricePerPerson && (
            <p class="text-ayaba-muted text-sm mt-1">{pricePerPerson}</p>
          )}
        </div>

        {/* Bonus offert */}
        <div class="mb-6">
          <p class="text-[11px] uppercase tracking-[1.5px] text-ayaba-terra font-semibold mb-2">{t(locale, 'home.bonusLabel')}</p>
          <ul class="space-y-1.5">
            {bonuses.map((bonus) => (
              <li class="flex items-center gap-2">
                <span class="text-ayaba-terra font-bold text-sm" aria-hidden="true">&#9733;</span>
                <span class="text-ayaba-dark text-sm">{bonus}</span>
              </li>
            ))}
          </ul>
        </div>

        {/* CTA */}
        <div class="mt-6">
          <AirbnbCta configId={configId} variant="primary" size="large" locale={locale} />
        </div>
      </div>
    </div>
  </div>
</section>
