---
import { Image } from 'astro:assets';
import { t, type Locale } from '../../i18n/utils';
import salon1 from '../../assets/images/apartments/salon1.png';
import salon3 from '../../assets/images/apartments/salon3.png';
import salon4 from '../../assets/images/apartments/salon4.png';
import cuisine1 from '../../assets/images/apartments/cuisine1.png';
import terrasse1 from '../../assets/images/apartments/terrasse1.png';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const images = [
  { src: salon1, alt: 'Salon — Maison Ayaba', big: true },
  { src: salon3, alt: 'Salon TV — Maison Ayaba' },
  { src: cuisine1, alt: 'Cuisine équipée — Maison Ayaba' },
  { src: terrasse1, alt: 'Terrasse — Maison Ayaba' },
  { src: salon4, alt: 'Salle à manger — Maison Ayaba' },
];

const features = [
  t(locale, 'home.showcaseFeature1'),
  t(locale, 'home.showcaseFeature2'),
  t(locale, 'home.showcaseFeature3'),
  t(locale, 'home.showcaseFeature4'),
  t(locale, 'home.showcaseFeature5'),
  t(locale, 'home.showcaseFeature6'),
];
---
<section id="photos" class="bg-white py-20">
  <div class="max-w-[1200px] mx-auto px-6 lg:px-16 text-center">
    <h2 class="font-heading text-ayaba-dark text-[26px] lg:text-[36px] font-bold mb-3">
      {t(locale, 'home.showcaseTitle')}
    </h2>
    <p class="text-ayaba-muted text-base lg:text-lg max-w-xl mx-auto mb-10">
      {t(locale, 'home.showcaseSubtitle')}
    </p>

    {/* Grille photo — 4 colonnes, première image en grand (2x2) */}
    <div class="grid grid-cols-2 md:grid-cols-4 gap-2 rounded-2xl overflow-hidden mb-8" id="photo-grid">
      <div class="col-span-2 row-span-2">
        <Image
          src={images[0].src}
          alt={images[0].alt}
          class="w-full h-full object-cover cursor-pointer hover:opacity-90 transition-opacity min-h-[200px] md:min-h-[280px]"
          widths={[480, 640, 960]}
          sizes="(max-width: 768px) 100vw, 50vw"
          loading="lazy"
          data-lightbox-group="showcase"
        />
      </div>
      {images.slice(1).map((img, idx) => (
        <div>
          <Image
            src={img.src}
            alt={img.alt}
            class="w-full h-full object-cover cursor-pointer hover:opacity-90 transition-opacity min-h-[96px] md:min-h-[120px]"
            widths={[320, 480, 640]}
            sizes="(max-width: 768px) 50vw, 25vw"
            loading="lazy"
            data-lightbox-group="showcase"
          />
        </div>
      ))}
    </div>

    <div class="flex flex-wrap justify-center gap-x-7 gap-y-2">
      {features.map((feature) => (
        <span class="flex items-center gap-1.5 text-sm">
          <span class="text-ayaba-success font-bold" aria-hidden="true">&#10003;</span>
          {feature}
        </span>
      ))}
    </div>
  </div>
</section>

