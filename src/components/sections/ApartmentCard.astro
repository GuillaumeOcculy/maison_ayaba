---
import { Image } from 'astro:assets';
import AirbnbCta from '../ui/AirbnbCta.astro';
import { t, type Locale } from '../../i18n/utils';

interface Props {
  images: ImageMetadata[];
  imageAlt: string;
  name: string;
  subtitle: string;
  price: string;
  priceUnit: string;
  priceNote?: string;
  capacity: number;
  features: string[];
  bonuses: string[];
  configId: '1ch' | '2ch' | '3ch';
  locale: Locale;
}

const { images, imageAlt, name, subtitle, price, priceUnit, priceNote, capacity, features, bonuses, configId, locale } = Astro.props;
const hasMultiple = images.length > 1;
const sliderId = `slider-${configId}`;
---
<article class="bg-white border border-[#ede6dd] rounded-2xl overflow-hidden hover:shadow-[0_8px_32px_rgba(44,24,16,0.1)] transition-shadow duration-300">
  <div class="relative h-[240px] overflow-hidden group">
    {images.length > 0 ? (
      <div id={sliderId} class="flex h-full transition-transform duration-300 ease-out" style="will-change: transform">
        {images.map((img, idx) => (
          <div class="w-full h-full shrink-0">
            <Image
              src={img}
              alt={`${imageAlt} — ${idx + 1}`}
              class="w-full h-full object-cover"
              widths={[420, 640]}
              sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 33vw"
              loading="lazy"
            />
          </div>
        ))}
      </div>
    ) : (
      <div
        class="w-full h-full bg-ayaba-cream flex items-center justify-center"
        role="img"
        aria-label={imageAlt}
      >
        <span class="text-ayaba-muted text-sm">{t(locale, 'home.photoPlaceholder')}</span>
      </div>
    )}

    {hasMultiple && (
      <>
        <button
          type="button"
          data-slider={sliderId}
          data-dir="prev"
          aria-label="Image précédente"
          class="absolute left-2 top-1/2 -translate-y-1/2 bg-white/80 hover:bg-white rounded-full w-8 h-8 flex items-center justify-center shadow opacity-0 group-hover:opacity-100 transition-opacity"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M15 19l-7-7 7-7"/></svg>
        </button>
        <button
          type="button"
          data-slider={sliderId}
          data-dir="next"
          aria-label="Image suivante"
          class="absolute right-2 top-1/2 -translate-y-1/2 bg-white/80 hover:bg-white rounded-full w-8 h-8 flex items-center justify-center shadow opacity-0 group-hover:opacity-100 transition-opacity"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7"/></svg>
        </button>
        <div class="absolute bottom-2 left-1/2 -translate-x-1/2 flex gap-1.5">
          {images.map((_, idx) => (
            <span
              data-dot={sliderId}
              data-index={idx}
              class:list={["w-2 h-2 rounded-full transition-colors", idx === 0 ? "bg-white" : "bg-white/50"]}
            />
          ))}
        </div>
      </>
    )}
  </div>

  <div class="p-7">
    <h3 class="font-heading text-[22px] text-ayaba-dark mb-1">{name}</h3>
    <p class="text-ayaba-muted text-sm">{subtitle}</p>
    <p class="text-ayaba-muted text-xs mb-4">{t(locale, 'home.capacityLabel', { count: String(capacity) })}</p>

    <div class="mb-4">
      <span class="text-ayaba-terra text-[28px] font-bold">{price}</span>
      <span class="text-ayaba-muted text-sm">{priceUnit}</span>
      {priceNote && (
        <p class="text-ayaba-muted text-xs mt-1">{priceNote}</p>
      )}
    </div>

    <p class="text-[11px] uppercase tracking-[1.5px] text-ayaba-muted font-semibold mb-2">{t(locale, 'home.includedLabel')}</p>
    <ul class="space-y-1.5 mb-5">
      {features.map((feature) => (
        <li class="flex items-center gap-2">
          <span class="text-ayaba-success font-bold text-sm" aria-hidden="true">&#10003;</span>
          <span class="text-ayaba-dark text-sm">{feature}</span>
        </li>
      ))}
    </ul>

    <p class="text-[11px] uppercase tracking-[1.5px] text-ayaba-terra font-semibold mb-2">{t(locale, 'home.bonusLabel')}</p>
    <ul class="space-y-1.5 mb-6">
      {bonuses.map((bonus) => (
        <li class="flex items-center gap-2">
          <span class="text-ayaba-terra font-bold text-sm" aria-hidden="true">&#9733;</span>
          <span class="text-ayaba-dark text-sm">{bonus}</span>
        </li>
      ))}
    </ul>

    <AirbnbCta configId={configId} variant="outline" locale={locale} />
  </div>
</article>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Button navigation
    document.querySelectorAll<HTMLButtonElement>('[data-slider][data-dir]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const sliderId = btn.dataset.slider!;
        const dir = btn.dataset.dir as 'prev' | 'next';
        const track = document.getElementById(sliderId);
        if (!track) return;

        const count = track.children.length;
        let current = parseInt(track.dataset.current || '0', 10);
        current = dir === 'next' ? (current + 1) % count : (current - 1 + count) % count;
        track.dataset.current = String(current);
        track.style.transform = `translateX(-${current * 100}%)`;

        document.querySelectorAll<HTMLSpanElement>(`[data-dot="${sliderId}"]`).forEach((dot) => {
          const idx = parseInt(dot.dataset.index || '0', 10);
          dot.className = `w-2 h-2 rounded-full transition-colors ${idx === current ? 'bg-white' : 'bg-white/50'}`;
        });
      });
    });

    // Touch swipe support for card sliders
    document.querySelectorAll<HTMLElement>('[id^="slider-"], [id^="book-slider-"]').forEach((track) => {
      const container = track.parentElement;
      if (!container) return;

      let startX = 0;
      let startY = 0;
      let isDragging = false;

      container.addEventListener('touchstart', (e) => {
        startX = e.touches[0].clientX;
        startY = e.touches[0].clientY;
        isDragging = true;
      }, { passive: true });

      container.addEventListener('touchmove', (e) => {
        if (!isDragging) return;
        const dx = e.touches[0].clientX - startX;
        const dy = e.touches[0].clientY - startY;
        if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 10) {
          e.preventDefault();
        }
      }, { passive: false });

      container.addEventListener('touchend', (e) => {
        if (!isDragging) return;
        isDragging = false;
        const dx = e.changedTouches[0].clientX - startX;
        if (Math.abs(dx) > 50) {
          const dir = dx < 0 ? 'next' : 'prev';
          const count = track.children.length;
          let current = parseInt(track.dataset.current || '0', 10);
          current = dir === 'next' ? (current + 1) % count : (current - 1 + count) % count;
          track.dataset.current = String(current);
          track.style.transform = `translateX(-${current * 100}%)`;

          document.querySelectorAll<HTMLSpanElement>(`[data-dot="${track.id}"]`).forEach((dot) => {
            const idx = parseInt(dot.dataset.index || '0', 10);
            dot.className = `w-2 h-2 rounded-full transition-colors ${idx === current ? 'bg-white' : 'bg-white/50'}`;
          });
        }
      }, { passive: true });
    });
  });
</script>
