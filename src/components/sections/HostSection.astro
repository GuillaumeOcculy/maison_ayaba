---
interface Props {
  label: string;
  title: string;
  description: string;
  ctaText: string;
  ctaHref: string;
}

const { label, title, description, ctaText, ctaHref } = Astro.props;
---
<section class="bg-ayaba-dark w-full">
  <div class="max-w-[600px] mx-auto px-6 py-20 text-center">
    <p class="text-ayaba-gold text-xs uppercase tracking-[1.5px] font-semibold mb-4">
      {label}
    </p>

    <h2 class="text-ayaba-cream font-heading text-[24px] lg:text-[28px] font-bold mb-4">
      {title}
    </h2>

    <p class="text-[#a09080] text-base mb-8">
      {description}
    </p>

    <a
      href={ctaHref}
      class="border border-white/30 text-ayaba-cream hover:bg-white/10 rounded-md px-4 py-2 font-body font-semibold text-sm transition-colors min-h-[44px] inline-flex items-center focus:outline-2 focus:outline-offset-2 focus:outline-ayaba-terra"
    >
      {ctaText}
    </a>
  </div>
</section>
