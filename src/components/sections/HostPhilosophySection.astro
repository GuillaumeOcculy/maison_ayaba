---
interface PhilosophyValue {
  icon: string;
  title: string;
  description: string;
}

interface Props {
  title: string;
  description: string;
  values: PhilosophyValue[];
}

const { title, description, values } = Astro.props;
---
<section class="bg-white py-16 lg:py-20">
  <div class="max-w-[1200px] mx-auto px-6 lg:px-16">
    <div class="text-center max-w-2xl mx-auto mb-12">
      <h2 class="font-heading text-ayaba-dark text-[24px] lg:text-[28px] font-bold mb-4">
        {title}
      </h2>
      <p class="text-ayaba-muted text-base leading-relaxed">
        {description}
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 max-w-4xl mx-auto">
      {values.map((value) => (
        <div class="text-center">
          <div class="w-14 h-14 rounded-full bg-white shadow-sm flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl" aria-hidden="true">{value.icon}</span>
          </div>
          <h3 class="font-body font-semibold text-ayaba-dark mb-2 text-base">{value.title}</h3>
          <p class="text-ayaba-muted text-sm leading-relaxed">{value.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
