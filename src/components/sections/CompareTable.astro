---
import { apartments, eurToFcfa } from '../../data/apartments';
import { t, type Locale } from '../../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const isEn = locale === 'en';
---
<section class="bg-white py-16 lg:py-20">
  <div class="max-w-[800px] mx-auto px-6 lg:px-16">
    <h2 class="font-heading text-ayaba-dark text-[26px] lg:text-[32px] font-bold mb-8 text-center">
      {t(locale, 'apartment.compareTitle')}
    </h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b-2 border-ayaba-gold/30">
            <th class="text-left py-3 pr-4 text-ayaba-muted font-semibold">{t(locale, 'apartment.compareHeader1')}</th>
            {apartments.map((apt) => (
              <th class="py-3 px-3 text-center font-heading text-ayaba-dark font-bold">
                {isEn ? `€${apt.pricePerNight.min}` : `${apt.pricePerNight.min}€`}<span class="text-ayaba-muted font-normal text-xs">/{isEn ? 'night' : 'nuit'}</span>
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          <tr class="border-b border-gray-100">
            <td class="py-3 pr-4 text-ayaba-muted">{t(locale, 'apartment.compareHeader2')}</td>
            <td class="py-3 px-3 text-center text-ayaba-dark">122 m²</td>
            <td class="py-3 px-3 text-center text-ayaba-dark">144 m²</td>
            <td class="py-3 px-3 text-center text-ayaba-dark">167 m²</td>
          </tr>
          <tr class="border-b border-gray-100">
            <td class="py-3 pr-4 text-ayaba-muted">{t(locale, 'apartment.compareHeader3')}</td>
            <td class="py-3 px-3 text-center text-ayaba-dark">1</td>
            <td class="py-3 px-3 text-center text-ayaba-dark">2</td>
            <td class="py-3 px-3 text-center text-ayaba-dark">3</td>
          </tr>
          <tr class="border-b border-gray-100">
            <td class="py-3 pr-4 text-ayaba-muted">{t(locale, 'apartment.compareHeader4')}</td>
            <td class="py-3 px-3 text-center text-ayaba-dark">1</td>
            <td class="py-3 px-3 text-center text-ayaba-dark">2</td>
            <td class="py-3 px-3 text-center text-ayaba-dark">3</td>
          </tr>
          <tr class="border-b border-gray-100">
            <td class="py-3 pr-4 text-ayaba-muted">{t(locale, 'apartment.compareHeader5')}</td>
            <td class="py-3 px-3 text-center text-ayaba-dark">2</td>
            <td class="py-3 px-3 text-center text-ayaba-dark">4</td>
            <td class="py-3 px-3 text-center text-ayaba-dark">6</td>
          </tr>
          <tr class="border-b border-gray-100">
            <td class="py-3 pr-4 text-ayaba-muted">{t(locale, 'apartment.compareHeader6')}</td>
            <td class="py-3 px-3 text-center text-ayaba-success font-bold">&#10003;</td>
            <td class="py-3 px-3 text-center text-ayaba-success font-bold">&#10003;</td>
            <td class="py-3 px-3 text-center text-ayaba-success font-bold">&#10003;</td>
          </tr>
          <tr>
            <td class="py-3 pr-4 text-ayaba-muted">FCFA</td>
            <td class="py-3 px-3 text-center text-ayaba-muted text-xs">~{eurToFcfa(60)}</td>
            <td class="py-3 px-3 text-center text-ayaba-muted text-xs">~{eurToFcfa(80)}</td>
            <td class="py-3 px-3 text-center text-ayaba-muted text-xs">~{eurToFcfa(100)}</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</section>
