---
interface KwaboItem {
  icon: string;
  title: string;
  description: string;
}

interface Props {
  label: string;
  title: string;
  subtitle: string;
  items: KwaboItem[];
}

const { label, title, subtitle, items } = Astro.props;
---
<section class="bg-ayaba-cream py-20">
  <div class="max-w-7xl mx-auto px-6 lg:px-16 text-center">
    <div class="w-[60px] h-[2px] bg-ayaba-gold mx-auto mb-6"></div>

    <p class="text-ayaba-gold text-xs uppercase tracking-[1.5px] font-semibold mb-4">
      {label}
    </p>

    <h2 class="font-heading text-ayaba-dark text-2xl lg:text-[32px] font-bold mb-3 max-w-2xl mx-auto">
      {title}
    </h2>

    <p class="text-ayaba-muted text-base mb-12 max-w-xl mx-auto">
      {subtitle}
    </p>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-7 max-w-4xl mx-auto">
      {items.map((item) => (
        <div class="flex flex-col items-center">
          <div class="w-14 h-14 rounded-full bg-white shadow-sm flex items-center justify-center mb-4">
            <span class="text-2xl" aria-hidden="true">{item.icon}</span>
          </div>
          <h3 class="font-body font-semibold text-ayaba-dark mb-1 text-base">{item.title}</h3>
          <p class="text-ayaba-muted text-sm">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
