---
import { t, type Locale } from '../../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

// Ordre d'affichage : Ore (7) puis Frantz (3) en tête, puis les autres.
const reviews = [7, 3, 1, 2, 4, 5, 6].map((n) => ({
  text: t(locale, `home.review${n}Text`),
  author: t(locale, `home.review${n}Author`),
}));
---
<section class="bg-white py-16 lg:py-20">
  <div class="max-w-[960px] mx-auto px-6 lg:px-16">
    <h2 class="font-heading text-ayaba-dark text-[24px] lg:text-[32px] font-bold text-center mb-2">
      {t(locale, 'home.reviewsTitle')}
    </h2>
    <p class="text-center text-lg mb-8">
      <span class="text-ayaba-gold">★★★★★</span>
      <span class="text-ayaba-dark text-base font-semibold">5/5 · {t(locale, 'home.reviewsCount')} {t(locale, 'home.reviewsSource')}</span>
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {reviews.map((review) => (
        <div class="bg-ayaba-cream rounded-xl p-6">
          <p class="text-ayaba-gold text-sm mb-2">★★★★★</p>
          <p class="text-ayaba-dark text-sm leading-relaxed italic mb-3">"{review.text}"</p>
          <p class="text-ayaba-muted text-[13px] font-semibold">— {review.author}</p>
        </div>
      ))}
    </div>
  </div>
</section>
