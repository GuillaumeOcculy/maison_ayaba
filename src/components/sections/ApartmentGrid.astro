---
import { Image } from 'astro:assets';
import GuestSelector from '../ui/GuestSelector.astro';
import ApartmentFloorPlan from '../ui/ApartmentFloorPlan.astro';
import { t, type Locale } from '../../i18n/utils';
import salon1 from '../../assets/images/apartments/salon1.png';
import salon3 from '../../assets/images/apartments/salon3.png';
import salon4 from '../../assets/images/apartments/salon4.png';
import cuisine1 from '../../assets/images/apartments/cuisine1.png';
import terrasse1 from '../../assets/images/apartments/terrasse1.png';
import chambre1Img from '../../assets/images/apartments/chambre1.png';
import chambre1Img2 from '../../assets/images/apartments/chambre1-2.png';
import chambre2Img from '../../assets/images/apartments/chambre2.png';
import chambre2Img2 from '../../assets/images/apartments/chambre2-2.png';
import chambre3Img from '../../assets/images/apartments/chambre3.png';
import chambre3Img2 from '../../assets/images/apartments/chambre3-2.png';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const showcaseImages = [
  { src: salon1, alt: 'Salon — Maison Ayaba' },
  { src: salon3, alt: 'Salon avec TV — Maison Ayaba' },
  { src: cuisine1, alt: 'Cuisine équipée — Maison Ayaba' },
  { src: terrasse1, alt: 'Terrasse — Maison Ayaba' },
  { src: salon4, alt: 'Salon et salle à manger — Maison Ayaba' },
  { src: chambre1Img, alt: 'Chambre 1 — Maison Ayaba' },
  { src: chambre1Img2, alt: 'Chambre 1 — Maison Ayaba' },
  { src: chambre2Img, alt: 'Chambre 2 — Maison Ayaba' },
  { src: chambre2Img2, alt: 'Chambre 2 — Maison Ayaba' },
  { src: chambre3Img, alt: 'Chambre 3 — Maison Ayaba' },
  { src: chambre3Img2, alt: 'Chambre 3 — Maison Ayaba' },
];

const showcaseFeatures = [
  t(locale, 'home.apartmentShowcaseFeature1'),
  t(locale, 'home.apartmentShowcaseFeature2'),
  t(locale, 'home.apartmentShowcaseFeature3'),
  t(locale, 'home.apartmentShowcaseFeature4'),
];

---

{/* Section 1: Apartment showcase — espaces communs */}
<section id="configurations" class="bg-white py-20">
  <div class="max-w-[1200px] mx-auto px-6 lg:px-16">
    <div class="text-center mb-12">
      <h2 class="font-heading text-ayaba-dark text-[28px] lg:text-[36px] font-bold mb-3">
        {t(locale, 'home.apartmentShowcaseTitle')}
      </h2>
      <p class="text-ayaba-muted text-base lg:text-lg max-w-2xl mx-auto">
        {t(locale, 'home.apartmentShowcaseSubtitle')}
      </p>
    </div>

    {/* Mobile: carrousel swipable */}
    <div class="md:hidden relative rounded-2xl overflow-hidden aspect-[4/3] mb-10">
      <div id="showcase-slider" class="flex h-full transition-transform duration-300 ease-out" style="will-change: transform">
        {showcaseImages.map((img) => (
          <div class="w-full h-full shrink-0">
            <Image
              src={img.src}
              alt={img.alt}
              class="w-full h-full object-cover"
              widths={[480, 640]}
              sizes="100vw"
              loading="lazy"
            />
          </div>
        ))}
      </div>
      <div class="absolute bottom-3 left-1/2 -translate-x-1/2 flex gap-1.5">
        {showcaseImages.map((_, idx) => (
          <span
            data-dot="showcase-slider"
            data-index={idx}
            class:list={["w-2 h-2 rounded-full transition-colors", idx === 0 ? "bg-white" : "bg-white/50"]}
          />
        ))}
      </div>
    </div>

    {/* Desktop: grille masonry — espaces communs + chambres */}
    <div class="hidden md:grid md:grid-cols-4 gap-3 mb-10 rounded-2xl overflow-hidden">
      {/* Rangée 1 : salon grand + 3 petites */}
      <div class="col-span-2 row-span-2 max-h-[400px]">
        <Image src={showcaseImages[0].src} alt={showcaseImages[0].alt} class="w-full h-full object-cover" widths={[640, 960]} sizes="50vw" loading="lazy" />
      </div>
      {showcaseImages.slice(1, 5).map((img) => (
        <div class="max-h-[196px]">
          <Image src={img.src} alt={img.alt} class="w-full h-full object-cover" widths={[400, 640]} sizes="25vw" loading="lazy" />
        </div>
      ))}
      {/* Rangée 2 : les 3 chambres (2 photos chacune) */}
      {showcaseImages.slice(5).map((img) => (
        <div class="max-h-[220px]">
          <Image src={img.src} alt={img.alt} class="w-full h-full object-cover" widths={[400, 640]} sizes="25vw" loading="lazy" />
        </div>
      ))}
    </div>

    {/* Features list */}
    <div class="flex flex-wrap justify-center gap-x-8 gap-y-3 mb-6">
      {showcaseFeatures.map((feature) => (
        <div class="flex items-center gap-2">
          <span class="text-ayaba-success font-bold" aria-hidden="true">&#10003;</span>
          <span class="text-ayaba-dark text-sm lg:text-base">{feature}</span>
        </div>
      ))}
    </div>

    <div class="bg-ayaba-cream/60 border border-ayaba-gold/20 rounded-xl px-6 py-4 max-w-2xl mx-auto text-center">
      <p class="text-ayaba-dark text-sm lg:text-base">
        {t(locale, 'home.configExplainer')}
      </p>
      <ApartmentFloorPlan locale={locale} />
    </div>

    <div class="mt-12">
      <GuestSelector locale={locale} variant="compact" />
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const track = document.getElementById('showcase-slider');
    if (!track) return;
    const container = track.parentElement;
    if (!container) return;

    const count = track.children.length;
    let current = 0;
    let startX = 0, startY = 0, isDragging = false;

    function goTo(index: number) {
      current = ((index % count) + count) % count;
      track.style.transform = `translateX(-${current * 100}%)`;
      document.querySelectorAll<HTMLSpanElement>('[data-dot="showcase-slider"]').forEach((dot) => {
        const idx = parseInt(dot.dataset.index || '0', 10);
        dot.className = `w-2 h-2 rounded-full transition-colors ${idx === current ? 'bg-white' : 'bg-white/50'}`;
      });
    }

    // Auto-play every 3s, pause on touch
    let autoPlay = setInterval(() => goTo(current + 1), 3000);

    container.addEventListener('touchstart', (e) => {
      clearInterval(autoPlay);
      startX = e.touches[0].clientX; startY = e.touches[0].clientY; isDragging = true;
    }, { passive: true });

    container.addEventListener('touchmove', (e) => {
      if (!isDragging) return;
      const dx = e.touches[0].clientX - startX, dy = e.touches[0].clientY - startY;
      if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 10) e.preventDefault();
    }, { passive: false });

    container.addEventListener('touchend', (e) => {
      if (!isDragging) return;
      isDragging = false;
      const dx = e.changedTouches[0].clientX - startX;
      if (Math.abs(dx) > 50) goTo(dx < 0 ? current + 1 : current - 1);
      autoPlay = setInterval(() => goTo(current + 1), 3000);
    }, { passive: true });
  });
</script>
