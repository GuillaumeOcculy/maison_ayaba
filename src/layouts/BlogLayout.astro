---
import { Image } from 'astro:assets';
import BaseLayout from './BaseLayout.astro';
import SchemaOrg from '../components/seo/SchemaOrg.astro';
import { t, type Locale } from '../i18n/utils';
import { baseUrl } from '../data/siteConfig';
import { getCollection } from 'astro:content';

interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  locale: Locale;
  title: string;
  description: string;
  pubDate: Date;
  tags?: string[];
  ogImage?: string;
  alternateSlug: string;
  faqItems?: FAQItem[];
  currentPath: string;
  heroImage?: ImageMetadata;
  heroImageAlt?: string;
  articleImages?: Record<string, { src: ImageMetadata; alt: string }>;
}

const {
  locale,
  title,
  description,
  pubDate,
  tags = [],
  ogImage,
  alternateSlug,
  faqItems,
  currentPath,
  heroImage,
  heroImageAlt = '',
  articleImages = {},
} = Astro.props;

const otherLocale = locale === 'fr' ? 'en' : 'fr';
const alternateUrls = {
  [locale]: currentPath,
  [otherLocale]: `/${otherLocale}/blog/${alternateSlug}/`,
} as Record<Locale, string>;

const formattedDate = pubDate.toLocaleDateString(locale === 'fr' ? 'fr-FR' : 'en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const homeLabel = t(locale, 'nav.home');
const blogLabel = t(locale, 'nav.blog');
const homeUrl = locale === 'fr' ? '/' : '/en/';
const blogUrl = `/${locale}/blog/`;

const breadcrumbItems = [
  { name: homeLabel, url: homeUrl },
  { name: blogLabel, url: blogUrl },
  { name: title, url: currentPath },
];

// Suggested articles
const allPosts = await getCollection('blog');
const currentSlug = currentPath.split('/').filter(Boolean).pop() || '';
const suggestedPosts = allPosts
  .filter((post) => post.id.startsWith(`${locale}/`) && !post.id.endsWith(currentSlug))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 2);

const tagColors = [
  'bg-ayaba-terra/10 text-ayaba-terra',
  'bg-ayaba-gold/15 text-ayaba-dark',
  'bg-ayaba-success/10 text-ayaba-success',
];
---
<BaseLayout locale={locale} title={title} description={description} ogImage={ogImage} alternateUrls={alternateUrls}>
  <Fragment slot="head">
    <meta property="og:type" content="article" />
    <meta property="article:published_time" content={pubDate.toISOString()} />
  </Fragment>

  <SchemaOrg type="BreadcrumbList" locale={locale} breadcrumbItems={breadcrumbItems} />
  {faqItems && faqItems.length > 0 && (
    <SchemaOrg type="FAQPage" locale={locale} faqItems={faqItems} />
  )}

  {/* Hero article */}
  <section class="bg-white pt-12 pb-0 lg:pt-16">
    <div class="max-w-[800px] mx-auto px-6 lg:px-16">
      <nav class="mb-8">
        <a
          href={blogUrl}
          class="text-ayaba-terra hover:text-ayaba-terra/80 font-body text-sm transition-colors inline-flex items-center gap-1"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          {t(locale, 'blog.backToList')}
        </a>
      </nav>

      {/* Tags */}
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-6">
          {tags.slice(0, 4).map((tag, tagIdx) => (
            <span class:list={[
              'text-xs font-body font-medium px-3 py-1.5 rounded-full',
              tagColors[tagIdx % tagColors.length],
            ]}>
              {tag}
            </span>
          ))}
        </div>
      )}

      <h1 class="font-heading text-ayaba-dark text-[28px] md:text-[36px] lg:text-[42px] font-bold leading-tight mb-6">
        {title}
      </h1>

      <div class="flex items-center gap-3 text-ayaba-muted font-body text-sm mb-10">
        <time datetime={pubDate.toISOString()}>{formattedDate}</time>
      </div>
    </div>

    {/* Hero image */}
    {heroImage && (
      <div class="max-w-[1000px] mx-auto px-6 lg:px-16 mb-0">
        <div class="rounded-2xl overflow-hidden">
          <Image
            src={heroImage}
            alt={heroImageAlt}
            widths={[600, 900, 1200]}
            sizes="(max-width: 768px) 100vw, 900px"
            class="w-full h-[300px] md:h-[400px] lg:h-[450px] object-cover"
            loading="eager"
          />
        </div>
      </div>
    )}
  </section>

  {/* Article content */}
  <article class="bg-white py-12 lg:py-16">
    <div class="max-w-[800px] mx-auto px-6 lg:px-16">
      <div class="prose prose-lg max-w-none
        prose-headings:font-heading prose-headings:text-ayaba-dark
        prose-h2:text-[24px] prose-h2:lg:text-[28px] prose-h2:mt-16 prose-h2:mb-6
        prose-h3:text-[20px] prose-h3:mt-12 prose-h3:mb-5
        prose-p:font-body prose-p:text-ayaba-dark/85 prose-p:leading-[1.85] prose-p:mb-6
        prose-a:text-ayaba-terra prose-a:underline prose-a:underline-offset-4 hover:prose-a:text-ayaba-terra/80
        prose-strong:text-ayaba-dark prose-strong:font-semibold
        prose-ul:my-6 prose-ul:space-y-3 prose-li:text-ayaba-dark/85 prose-li:leading-relaxed
        prose-ol:my-6 prose-ol:space-y-3
        prose-blockquote:border-l-4 prose-blockquote:border-ayaba-terra prose-blockquote:bg-ayaba-cream prose-blockquote:py-4 prose-blockquote:px-6 prose-blockquote:rounded-r-lg prose-blockquote:text-ayaba-dark/80 prose-blockquote:not-italic
        prose-table:my-8 prose-th:bg-ayaba-cream prose-th:text-ayaba-dark prose-th:font-semibold prose-th:px-4 prose-th:py-3 prose-td:px-4 prose-td:py-3 prose-td:border-b prose-td:border-gray-100
        prose-hr:my-14 prose-hr:border-gray-200
        prose-img:rounded-xl prose-img:my-10
      ">
        <slot />
      </div>
    </div>
  </article>

  {/* CTA vers les logements */}
  <section class="bg-ayaba-cream py-16 lg:py-20">
    <div class="max-w-[800px] mx-auto px-6 lg:px-16 text-center">
      <h2 class="font-heading text-ayaba-dark text-[24px] lg:text-[28px] font-bold mb-4">
        {t(locale, 'blog.articleCtaTitle')}
      </h2>
      <p class="text-ayaba-muted text-base mb-8 max-w-lg mx-auto">
        {t(locale, 'blog.articleCtaSubtitle')}
      </p>
      <a
        href={locale === 'fr' ? '/#logements' : '/en/#logements'}
        class="inline-flex items-center justify-center bg-ayaba-terra text-white font-semibold text-base px-8 py-3 rounded-full hover:bg-ayaba-terra/90 transition-colors min-h-[44px] focus:outline-2 focus:outline-offset-2 focus:outline-ayaba-terra"
      >
        {t(locale, 'blog.articleCtaLink')}
      </a>
    </div>
  </section>

  {/* Suggested articles */}
  {suggestedPosts.length > 0 && (
    <section class="bg-white py-16 lg:py-20">
      <div class="max-w-[1200px] mx-auto px-6 lg:px-16">
        <h2 class="font-heading text-ayaba-dark text-[24px] lg:text-[28px] font-bold mb-10 text-center">
          {t(locale, 'blog.readNext')}
        </h2>
        <div class="grid gap-8 md:grid-cols-2 max-w-3xl mx-auto">
          {suggestedPosts.map((post) => {
            const postSlug = post.id.replace(new RegExp(`^${locale}/`), '');
            const postImg = articleImages[postSlug];
            const postDate = post.data.pubDate.toLocaleDateString(
              locale === 'fr' ? 'fr-FR' : 'en-US',
              { year: 'numeric', month: 'long', day: 'numeric' }
            );
            return (
              <article class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
                <a href={`/${locale}/blog/${postSlug}/`} class="block">
                  {postImg ? (
                    <Image
                      src={postImg.src}
                      alt={postImg.alt}
                      widths={[400, 600]}
                      sizes="(max-width: 768px) 100vw, 400px"
                      class="w-full h-40 object-cover"
                      loading="lazy"
                    />
                  ) : (
                    <div class="h-40 bg-gradient-to-br from-ayaba-terra/10 via-ayaba-cream to-ayaba-gold/10"></div>
                  )}
                </a>
                <div class="p-6">
                  <h3 class="font-heading text-lg text-ayaba-dark leading-snug mb-3">
                    <a href={`/${locale}/blog/${postSlug}/`} class="hover:text-ayaba-terra transition-colors">
                      {post.data.title}
                    </a>
                  </h3>
                  <time class="text-xs text-ayaba-muted font-body" datetime={post.data.pubDate.toISOString()}>
                    {postDate}
                  </time>
                </div>
              </article>
            );
          })}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
