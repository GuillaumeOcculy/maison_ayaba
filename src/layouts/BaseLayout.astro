---
import '../styles/global.css';
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';
import StickyMobileCta from '../components/ui/StickyMobileCta.astro';
import WhatsAppButton from '../components/ui/WhatsAppButton.astro';
import MetaTags from '../components/seo/MetaTags.astro';
import type { Locale } from '../i18n/utils';
import { t } from '../i18n/utils';

interface Props {
  locale: Locale;
  title: string;
  description: string;
  ogImage?: string;
  hideHeader?: boolean;
  alternateUrls?: Partial<Record<Locale, string>>;
}

const { locale, title, description, ogImage, hideHeader, alternateUrls } = Astro.props;
const skipText = t(locale, 'accessibility.skipToContent');
const ga4Id = import.meta.env.GA4_MEASUREMENT_ID;
---
<!DOCTYPE html>
<html lang={locale} class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&family=Playfair+Display:wght@700&display=swap" rel="stylesheet" />
    <MetaTags title={title} description={description} locale={locale} currentPath={Astro.url.pathname} ogImage={ogImage} alternateUrls={alternateUrls} />
    {ga4Id && (
      <Fragment>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`}></script>
        <script is:inline define:vars={{ ga4Id }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', ga4Id);
        </script>
        <!-- GA4 Conversions: Admin → Events → Mark "airbnb_click" as conversion.
             Event params: config (1ch/2ch/3ch), page (pathname). -->
      </Fragment>
    )}
    <slot name="head" />
  </head>
  <body class="bg-white text-ayaba-dark font-body min-h-screen flex flex-col">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-50 focus:bg-ayaba-terra focus:text-white focus:px-4 focus:py-2 focus:rounded focus:outline-2 focus:outline-offset-2 focus:outline-ayaba-terra"
    >
      {skipText}
    </a>
    {!hideHeader && <Header locale={locale} currentPath={Astro.url.pathname} alternateUrls={alternateUrls} />}
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <Footer locale={locale} alternateUrls={alternateUrls} />
    <StickyMobileCta locale={locale} />
    <WhatsAppButton locale={locale} />
  </body>
</html>
